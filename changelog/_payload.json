7,1175,1178,1186,1193,1196,1203,1207,1218,1222,1225,1264],[1147,1148,1149],"warning",{},[241,1150,1151,1152,1157,1158,1162,1163,1166],{},"本文发表于 ",[244,1153,1156],{"href":1154,"rel":1155},"https://github.com/nuxt/content",[248],"Content"," 和 ",[244,1159,249],{"href":1160,"rel":1161},"https://github.com/nuxtlabs/studio-module",[248]," 模块于 2025 年 1 月 6 日合并之前。因此，文中内容可能存在一些不一致之处。Studio 模块现已废弃，并作为 Content 模块的可选功能提供。请参阅 ",[244,1164,1165],{"href":6},"此指南"," 了解如何启用。",[273,1168,1170,1157,1172,1174],{"id":1169},"yaml-和-json-文件的自动生成表单",[252,1171,54],{},[252,1173,58],{}," 文件的自动生成表单",[267,1176],{":controls":269,":loop":269,"src":1177},"https://res.cloudinary.com/nuxt/video/upload/v1730132248/yml-json-form_n9czcs.mp4",[241,1179,1180,1181,1157,1183,1185],{},"延续我们让 Nuxt Studio 成为非技术用户编辑 Nuxt 网站内容工具的旅程，我们很高兴地宣布，现在可以通过生成的视觉表单来编辑 ",[252,1182,54],{},[252,1184,58],{}," 文件。这次更新免去了用户直接操作复杂文件语法（如 YAML 或 JSON）的需求。",[1187,1188,1190],"callout",{"icon":1189},"i-ph-info",[241,1191,1192],{},"目前数组尚未通过表单支持，但我们计划在 Nuxt Content v3 发布集合和用户定义的 schema 后进行支持。详见下文章节。",[299,1194,1195],{"id":1195},"同步导航",[241,1197,1198,1199,1202],{},"此次更新同时改进了非 Markdown 格式（如 YAML 和 JSON）预览与所选文件间的同步导航。请将 Studio 模块更新至最新版本 ",[252,1200,1201],{},"v2.2.0"," 以应用此修复。",[273,1204,1206],{"id":1205},"迈向-nuxt-content-v3","迈向 Nuxt Content v3",[241,1208,1209,1210,1217],{},"我们很高兴地宣布，Nuxt Content v3 的第四个 alpha 版本已发布，且 ",[244,1211,1214],{"href":1212,"rel":1213},"https://content.nuxt.com/",[248],[277,1215,1216],{},"草稿文档"," 已开放。",[299,1219,1221],{"id":1220},"下一步","下一步？",[241,1223,1224],{},"未来几个月，我们将专注于测试和优化 Nuxt Content v3，确保其稳健且适合生产环境发布。以下是与 Nuxt Studio 相关的主要改进：",[972,1226,1227,1241,1255],{},[975,1228,1229,1232,1233,1236,1237,1240],{},[277,1230,1231],{},"合并 Studio 模块","：不久后，Studio 模块将直接集成进 Nuxt Content。Nuxt Content v3 发布后，只需在 ",[252,1234,1235],{},"nuxt.config.ts"," 文件中设置 ",[252,1238,1239],{},"content.editor: true"," 即可启用 Studio。该简化意味着无需额外模块，安装更快捷。",[975,1242,1243,1246,1247,1157,1251,1254],{},[277,1244,1245],{},"统一文档","：模块合并后，我们将把 ",[244,1248,1156],{"href":1249,"rel":1250},"https://content.nuxt.com",[248],[244,1252,249],{"href":246,"rel":1253},[248]," 的文档及网站合并为一个综合资源。Studio 平台本身（用户登录后可用）将作为独立站点保留。",[975,1256,1257,1260,1261,1263],{},[277,1258,1259],{},"充分利用 Studio 中的数据结构和集合","：借助 Nuxt Content v3，Studio 平台将支持并适配 ",[244,1262,25],{"href":32}," 和用户定义的 schema，实现针对 YAML、JSON 文件及 Markdown 的 front-matter 的基于 schema 的表单生成。",[241,1265,1266],{},"这些更新体现了我们为您的 Nuxt 网站提供最佳内容编辑平台的承诺。敬请期待！",{"title":341,"searchDepth":398,"depth":398,"links":1268},[1269,1273],{"id":1169,"depth":370,"text":1270,"children":1271},"YAML 和 JSON 文件的自动生成表单",[1272],{"id":1195,"depth":383,"text":1195},{"id":1205,"depth":370,"text":1206,"children":1274},[1275],{"id":1220,"depth":383,"text":1221},"studio","2024-10-28T01:00:00.000Z","通过自动生成的表单编辑 YAML 和 JSON 文件。",{"src":1280},"/docs/studio/json-yml-forms.png",{"name":1140},"/changelog/yaml-json-form",{"title":1140,"description":1278},"changelog/yaml-json-form","PcyEHcmKBFPq_ZS9GCanTXuThC2Tea0ZaKYBBthdFy8",{"id":1287,"title":1288,"authors":1289,"body":1292,"category":1276,"date":1862,"description":1863,"draft":42,"extension":1129,"image":1864,"meta":1866,"navigation":222,"path":1867,"seo":1868,"stem":1869,"__hash__":1870},"posts/changelog/frontmatter-form.md","可视化 Front-matter 编辑",[1290],{"name":233,"avatar":1291,"to":234},{"src":236},{"type":238,"value":1293,"toc":1848},[1294,1310,1314,1320,1324,1328,1336,1341,1344,1347,1350,1354,1362,1366,1378,1381,1384,1392,1395,1399,1402,1406,1412,1416,1419,1708,1712,1715,1718,1839,1845],[1147,1295,1296],{},[241,1297,1298,1299,1157,1302,1305,1306,1309],{},"本文发布于 2025 年 1 月 6 日 ",[244,1300,1156],{"href":1154,"rel":1301},[248],[244,1303,249],{"href":1160,"rel":1304},[248]," 模块合并之前。因此，本文可能存在一些不一致之处。Studio 模块现已弃用，作为 Content 模块的可选功能提供。请参阅",[244,1307,1308],{"href":6},"这份指南","了解如何启用。",[273,1311,1313],{"id":1312},"可视化-front-matter-编辑","可视化 Front-Matter 编辑",[241,1315,1316,1317,1319],{},"现在您无需编写 ",[252,1318,54],{}," 语法即可编辑 markdown front-matter。Nuxt Studio 会自动生成用户友好的表单，简化元数据编辑。",[267,1321],{":autoplay":269,":controls":269,":loop":269,"poster":1322,"src":1323},"https://res.cloudinary.com/nuxt/video/upload/v1729157955/frontmatterform2_rmh58v.jpg","https://res.cloudinary.com/nuxt/video/upload/v1729157955/frontmatterform2_rmh58v.mp4",[273,1325,1327],{"id":1326},"什么是-front-matter","什么是 Front-matter？",[241,1329,1330,1331,1335],{},"Front-matter 是基于 Markdown 的 CMS 中用于为页面提供元数据（如描述、标题等）的约定。在 ",[244,1332,1334],{"href":1333},"/docs/files/markdown#front-matter","Nuxt Content"," 中，front-matter 使用的是 YAML 语法。",[1187,1337,1338],{"icon":1189,"to":1333},[241,1339,1340],{},"关于 front-matter 语法的详细信息，请参阅 Nuxt Content 文档。",[273,1342,1343],{"id":1343},"我们非技术编辑器的最后一环",[241,1345,1346],{},"Nuxt Studio 从发布编辑器起就以非技术用户为设计核心。我们的目标是让每个人都能轻松编辑 markdown 和内容。",[241,1348,1349],{},"自动生成 front-matter 表单是下一步的合理进展。通过摆脱 YAML 语法的复杂性，简化了非开发者的编辑流程，提供动态输入选项，如图片选择器、日期选择器、布尔切换等。此增强使我们实现了完全可视化且用户友好的内容管理体验。",[273,1351,1353],{"id":1352},"扩展至所有-yaml-和-json-文件","扩展至所有 YAML 和 JSON 文件",[241,1355,1356,1357,1157,1359,1361],{},"不久之后，表单生成功能将扩展至您在 Nuxt Studio 中编辑的所有 ",[252,1358,54],{},[252,1360,58],{}," 文件，让结构化数据的操作更为轻松便捷。",[273,1363,1365],{"id":1364},"展望-nuxt-content-v3","展望 Nuxt Content v3",[1187,1367,1369],{"icon":1368},"i-ph-lightbulb",[241,1370,1371,1372,1377],{},"本节内容仅为 ",[244,1373,1376],{"href":1374,"rel":1375},"https://github.com/nuxt/content/tree/v3",[248],"Nuxt Content v3"," 的预告，我们将很快发布更详尽的博文。",[241,1379,1380],{},"我们正积极开发下一重大版本 Nuxt Content，这将带来显著的性能提升和新功能，进一步提升内容管理体验。",[299,1382,1383],{"id":1383},"性能优化",[241,1385,1386,1387,1391],{},"Nuxt Content v2 的一大挑战是需要较大的包体积来存储所有内容文件，这在向边缘平台（如 ",[244,1388,120],{"href":1389,"rel":1390},"https://hub.nuxt.com/",[248],"）部署时造成了问题。",[241,1393,1394],{},"为解决此问题，Nuxt Content v3 在生产环境中不再使用基于文件的存储方式，而是采用 SQL 数据库系统。此变更对用户透明。我们为开发模式、静态生成、服务器渲染及通过 NuxtHub 的边缘部署提供零配置支持。",[299,1396,1398],{"id":1397},"引入-collections集合","引入 Collections（集合）",[241,1400,1401],{},"Collections 是 Nuxt Content 项目中相关内容项的分组，帮助更高效地组织和管理大型数据集。",[1034,1403,1405],{"id":1404},"定义-collections","定义 Collections",[241,1407,1408,1409,1411],{},"您可以在 ",[252,1410,339],{}," 文件中定义 collections，Nuxt Content 将用它配置数据库结构、类型工具及用于查找、解析和查询内容的方法。",[1034,1413,1415],{"id":1414},"collections-方案schema","Collections 方案（Schema）",[241,1417,1418],{},"方案可确保 collections 内部的一致性，并改善 TypeScript 类型定义，增强与 Nuxt Content 工具的集成。",[335,1420,1422],{"className":337,"code":1421,"filename":339,"language":340,"meta":341,"style":341},"import { defineCollection, z } from '@nuxt/content'\n\n// 导出 collections\nexport const collections = {\n  // 使用 `defineCollection` 工具定义 collection\n  posts: defineCollection({\n    // 指定该 collection 中内容的类型\n    type: 'page',\n    // 加载匹配此模式的所有文件\n    source: 'blog/**/*.md',\n    // 为该 collection 定义自定义 schema\n    schema: z.object({\n      date: z.date(),\n      image: z.object({\n        src: z.string(),\n        alt: z.string()\n      }),\n      badge: z.object({\n        label: z.string(),\n        color: z.string()\n      })\n    })\n  }),\n}\n",[252,1423,1424,1450,1455,1461,1477,1482,1495,1500,1515,1520,1536,1541,1558,1575,1592,1609,1625,1633,1650,1667,1682,1688,1694,1703],{"__ignoreMap":341},[345,1425,1426,1429,1432,1434,1436,1438,1440,1443,1445,1447],{"class":347,"line":348},[345,1427,1428],{"class":351},"import",[345,1430,1431],{"class":366}," {",[345,1433,391],{"class":362},[345,1435,516],{"class":366},[345,1437,444],{"class":362},[345,1439,623],{"class":366},[345,1441,1442],{"class":351}," from",[345,1444,406],{"class":366},[345,1446,320],{"class":409},[345,1448,1449],{"class":366},"'\n",[345,1451,1452],{"class":347,"line":370},[345,1453,1454],{"emptyLinePlaceholder":222},"\n",[345,1456,1457],{"class":347,"line":383},[345,1458,1460],{"class":1459},"sHwdD","// 导出 collections\n",[345,1462,1463,1465,1469,1472,1475],{"class":347,"line":398},[345,1464,352],{"class":351},[345,1466,1468],{"class":1467},"spNyl"," const",[345,1470,1471],{"class":362}," collections ",[345,1473,1474],{"class":366},"=",[345,1476,380],{"class":366},[345,1478,1479],{"class":347,"line":419},[345,1480,1481],{"class":1459},"  // 使用 `defineCollection` 工具定义 collection\n",[345,1483,1484,1487,1489,1491,1493],{"class":347,"line":436},[345,1485,1486],{"class":373},"  posts",[345,1488,377],{"class":366},[345,1490,391],{"class":358},[345,1492,363],{"class":362},[345,1494,367],{"class":366},[345,1496,1497],{"class":347,"line":457},[345,1498,1499],{"class":1459},"    // 指定该 collection 中内容的类型\n",[345,1501,1502,1505,1507,1509,1511,1513],{"class":347,"line":491},[345,1503,1504],{"class":373},"    type",[345,1506,377],{"class":366},[345,1508,406],{"class":366},[345,1510,410],{"class":409},[345,1512,413],{"class":366},[345,1514,416],{"class":366},[345,1516,1517],{"class":347,"line":547},[345,1518,1519],{"class":1459},"    // 加载匹配此模式的所有文件\n",[345,1521,1522,1525,1527,1529,1532,1534],{"class":347,"line":566},[345,1523,1524],{"class":373},"    source",[345,1526,377],{"class":366},[345,1528,406],{"class":366},[345,1530,1531],{"class":409},"blog/**/*.md",[345,1533,413],{"class":366},[345,1535,416],{"class":366},[345,1537,1538],{"class":347,"line":584},[345,1539,1540],{"class":1459},"    // 为该 collection 定义自定义 schema\n",[345,1542,1543,1546,1548,1550,1552,1554,1556],{"class":347,"line":630},[345,1544,1545],{"class":373},"    schema",[345,1547,377],{"class":366},[345,1549,444],{"class":362},[345,1551,447],{"class":366},[345,1553,450],{"class":358},[345,1555,363],{"class":362},[345,1557,367],{"class":366},[345,1559,1560,1563,1565,1567,1569,1571,1573],{"class":347,"line":648},[345,1561,1562],{"class":373},"      date",[345,1564,377],{"class":366},[345,1566,444],{"class":362},[345,1568,447],{"class":366},[345,1570,559],{"class":358},[345,1572,472],{"class":362},[345,1574,416],{"class":366},[345,1576,1577,1580,1582,1584,1586,1588,1590],{"class":347,"line":658},[345,1578,1579],{"class":373},"      image",[345,1581,377],{"class":366},[345,1583,444],{"class":362},[345,1585,447],{"class":366},[345,1587,450],{"class":358},[345,1589,363],{"class":362},[345,1591,367],{"class":366},[345,1