1195,1202,1206,1217,1221,1224,1263],[1146,1147,1148],"warning",{},[245,1149,1150,1151,1156,1157,1161,1162,1165],{},"本文发表于 ",[248,1152,1155],{"href":1153,"rel":1154},"https://github.com/nuxt/content",[252],"Content"," 和 ",[248,1158,253],{"href":1159,"rel":1160},"https://github.com/nuxtlabs/studio-module",[252]," 模块于 2025 年 1 月 6 日合并之前。因此，文中内容可能存在一些不一致之处。Studio 模块现已废弃，并作为 Content 模块的可选功能提供。请参阅 ",[248,1163,1164],{"href":6},"此指南"," 了解如何启用。",[277,1167,1169,1156,1171,1173],{"id":1168},"yaml-和-json-文件的自动生成表单",[256,1170,54],{},[256,1172,58],{}," 文件的自动生成表单",[271,1175],{":controls":273,":loop":273,"src":1176},"https://res.cloudinary.com/nuxt/video/upload/v1730132248/yml-json-form_n9czcs.mp4",[245,1178,1179,1180,1156,1182,1184],{},"延续我们让 Nuxt Studio 成为非技术用户编辑 Nuxt 网站内容工具的旅程，我们很高兴地宣布，现在可以通过生成的视觉表单来编辑 ",[256,1181,54],{},[256,1183,58],{}," 文件。这次更新免去了用户直接操作复杂文件语法（如 YAML 或 JSON）的需求。",[1186,1187,1189],"callout",{"icon":1188},"i-ph-info",[245,1190,1191],{},"目前数组尚未通过表单支持，但我们计划在 Nuxt Content v3 发布集合和用户定义的 schema 后进行支持。详见下文章节。",[303,1193,1194],{"id":1194},"同步导航",[245,1196,1197,1198,1201],{},"此次更新同时改进了非 Markdown 格式（如 YAML 和 JSON）预览与所选文件间的同步导航。请将 Studio 模块更新至最新版本 ",[256,1199,1200],{},"v2.2.0"," 以应用此修复。",[277,1203,1205],{"id":1204},"迈向-nuxt-content-v3","迈向 Nuxt Content v3",[245,1207,1208,1209,1216],{},"我们很高兴地宣布，Nuxt Content v3 的第四个 alpha 版本已发布，且 ",[248,1210,1213],{"href":1211,"rel":1212},"https://content.nuxt.com/",[252],[281,1214,1215],{},"草稿文档"," 已开放。",[303,1218,1220],{"id":1219},"下一步","下一步？",[245,1222,1223],{},"未来几个月，我们将专注于测试和优化 Nuxt Content v3，确保其稳健且适合生产环境发布。以下是与 Nuxt Studio 相关的主要改进：",[976,1225,1226,1240,1254],{},[979,1227,1228,1231,1232,1235,1236,1239],{},[281,1229,1230],{},"合并 Studio 模块","：不久后，Studio 模块将直接集成进 Nuxt Content。Nuxt Content v3 发布后，只需在 ",[256,1233,1234],{},"nuxt.config.ts"," 文件中设置 ",[256,1237,1238],{},"content.editor: true"," 即可启用 Studio。该简化意味着无需额外模块，安装更快捷。",[979,1241,1242,1245,1246,1156,1250,1253],{},[281,1243,1244],{},"统一文档","：模块合并后，我们将把 ",[248,1247,1155],{"href":1248,"rel":1249},"https://content.nuxt.com",[252],[248,1251,253],{"href":250,"rel":1252},[252]," 的文档及网站合并为一个综合资源。Studio 平台本身（用户登录后可用）将作为独立站点保留。",[979,1255,1256,1259,1260,1262],{},[281,1257,1258],{},"充分利用 Studio 中的数据结构和集合","：借助 Nuxt Content v3，Studio 平台将支持并适配 ",[248,1261,25],{"href":32}," 和用户定义的 schema，实现针对 YAML、JSON 文件及 Markdown 的 front-matter 的基于 schema 的表单生成。",[245,1264,1265],{},"这些更新体现了我们为您的 Nuxt 网站提供最佳内容编辑平台的承诺。敬请期待！",{"title":345,"searchDepth":374,"depth":374,"links":1267},[1268,1272],{"id":1168,"depth":374,"text":1269,"children":1270},"YAML 和 JSON 文件的自动生成表单",[1271],{"id":1194,"depth":387,"text":1194},{"id":1204,"depth":374,"text":1205,"children":1273},[1274],{"id":1219,"depth":387,"text":1220},"studio","2024-10-28T01:00:00.000Z","通过自动生成的表单编辑 YAML 和 JSON 文件。",{"src":1279},"/docs/studio/json-yml-forms.png",{"name":1139},"/changelog/yaml-json-form",{"title":1139,"description":1277},"changelog/yaml-json-form","3UaoulTlLairEbvH9knC4gvA7oRLOk8oDIN9WmWE9Zc",{"id":1286,"title":1287,"authors":1288,"body":1291,"categories":1124,"category":1275,"date":1858,"description":1859,"draft":42,"extension":1128,"image":1860,"meta":1862,"navigation":226,"path":1863,"seo":1864,"stem":1865,"__hash__":1866},"posts/changelog/frontmatter-form.md","可视化 Front-matter 编辑",[1289],{"name":237,"avatar":1290,"to":238},{"src":240},{"type":242,"value":1292,"toc":1847},[1293,1309,1313,1319,1323,1327,1335,1340,1343,1346,1349,1353,1361,1365,1377,1380,1383,1391,1394,1398,1401,1405,1411,1415,1418,1707,1711,1714,1717,1838,1844],[1146,1294,1295],{},[245,1296,1297,1298,1156,1301,1304,1305,1308],{},"本文发布于 2025 年 1 月 6 日 ",[248,1299,1155],{"href":1153,"rel":1300},[252],[248,1302,253],{"href":1159,"rel":1303},[252]," 模块合并之前。因此，本文可能存在一些不一致之处。Studio 模块现已弃用，作为 Content 模块的可选功能提供。请参阅",[248,1306,1307],{"href":6},"这份指南","了解如何启用。",[277,1310,1312],{"id":1311},"可视化-front-matter-编辑","可视化 Front-Matter 编辑",[245,1314,1315,1316,1318],{},"现在您无需编写 ",[256,1317,54],{}," 语法即可编辑 markdown front-matter。Nuxt Studio 会自动生成用户友好的表单，简化元数据编辑。",[271,1320],{":autoplay":273,":controls":273,":loop":273,"poster":1321,"src":1322},"https://res.cloudinary.com/nuxt/video/upload/v1729157955/frontmatterform2_rmh58v.jpg","https://res.cloudinary.com/nuxt/video/upload/v1729157955/frontmatterform2_rmh58v.mp4",[277,1324,1326],{"id":1325},"什么是-front-matter","什么是 Front-matter？",[245,1328,1329,1330,1334],{},"Front-matter 是基于 Markdown 的 CMS 中用于为页面提供元数据（如描述、标题等）的约定。在 ",[248,1331,1333],{"href":1332},"/docs/files/markdown#front-matter","Nuxt Content"," 中，front-matter 使用的是 YAML 语法。",[1186,1336,1337],{"icon":1188,"to":1332},[245,1338,1339],{},"关于 front-matter 语法的详细信息，请参阅 Nuxt Content 文档。",[277,1341,1342],{"id":1342},"我们非技术编辑器的最后一环",[245,1344,1345],{},"Nuxt Studio 从发布编辑器起就以非技术用户为设计核心。我们的目标是让每个人都能轻松编辑 markdown 和内容。",[245,1347,1348],{},"自动生成 front-matter 表单是下一步的合理进展。通过摆脱 YAML 语法的复杂性，简化了非开发者的编辑流程，提供动态输入选项，如图片选择器、日期选择器、布尔切换等。此增强使我们实现了完全可视化且用户友好的内容管理体验。",[277,1350,1352],{"id":1351},"扩展至所有-yaml-和-json-文件","扩展至所有 YAML 和 JSON 文件",[245,1354,1355,1356,1156,1358,1360],{},"不久之后，表单生成功能将扩展至您在 Nuxt Studio 中编辑的所有 ",[256,1357,54],{},[256,1359,58],{}," 文件，让结构化数据的操作更为轻松便捷。",[277,1362,1364],{"id":1363},"展望-nuxt-content-v3","展望 Nuxt Content v3",[1186,1366,1368],{"icon":1367},"i-ph-lightbulb",[245,1369,1370,1371,1376],{},"本节内容仅为 ",[248,1372,1375],{"href":1373,"rel":1374},"https://github.com/nuxt/content/tree/v3",[252],"Nuxt Content v3"," 的预告，我们将很快发布更详尽的博文。",[245,1378,1379],{},"我们正积极开发下一重大版本 Nuxt Content，这将带来显著的性能提升和新功能，进一步提升内容管理体验。",[303,1381,1382],{"id":1382},"性能优化",[245,1384,1385,1386,1390],{},"Nuxt Content v2 的一大挑战是需要较大的包体积来存储所有内容文件，这在向边缘平台（如 ",[248,1387,124],{"href":1388,"rel":1389},"https://hub.nuxt.com/",[252],"）部署时造成了问题。",[245,1392,1393],{},"为解决此问题，Nuxt Content v3 在生产环境中不再使用基于文件的存储方式，而是采用 SQL 数据库系统。此变更对用户透明。我们为开发模式、静态生成、服务器渲染及通过 NuxtHub 的边缘部署提供零配置支持。",[303,1395,1397],{"id":1396},"引入-collections集合","引入 Collections（集合）",[245,1399,1400],{},"Collections 是 Nuxt Content 项目中相关内容项的分组，帮助更高效地组织和管理大型数据集。",[1038,1402,1404],{"id":1403},"定义-collections","定义 Collections",[245,1406,1407,1408,1410],{},"您可以在 ",[256,1409,343],{}," 文件中定义 collections，Nuxt Content 将用它配置数据库结构、类型工具及用于查找、解析和查询内容的方法。",[1038,1412,1414],{"id":1413},"collections-方案schema","Collections 方案（Schema）",[245,1416,1417],{},"方案可确保 collections 内部的一致性，并改善 TypeScript 类型定义，增强与 Nuxt Content 工具的集成。",[339,1419,1421],{"className":341,"code":1420,"filename":343,"language":344,"meta":345,"style":345},"import { defineCollection, z } from '@nuxt/content'\n\n// 导出 collections\nexport const collections = {\n  // 使用 `defineCollection` 工具定义 collection\n  posts: defineCollection({\n    // 指定该 collection 中内容的类型\n    type: 'page',\n    // 加载匹配此模式的所有文件\n    source: 'blog/**/*.md',\n    // 为该 collection 定义自定义 schema\n    schema: z.object({\n      date: z.date(),\n      image: z.object({\n        src: z.string(),\n        alt: z.string()\n      }),\n      badge: z.object({\n        label: z.string(),\n        color: z.string()\n      })\n    })\n  }),\n}\n",[256,1422,1423,1449,1454,1460,1476,1481,1494,1499,1514,1519,1535,1540,1557,1574,1591,1608,1624,1632,1649,1666,1681,1687,1693,1702],{"__ignoreMap":345},[349,1424,1425,1428,1431,1433,1435,1437,1439,1442,1444,1446],{"class":351,"line":352},[349,1426,1427],{"class":355},"import",[349,1429,1430],{"class":370}," {",[349,1432,395],{"class":366},[349,1434,520],{"class":370},[349,1436,448],{"class":366},[349,1438,627],{"class":370},[349,1440,1441],{"class":355}," from",[349,1443,410],{"class":370},[349,1445,324],{"class":413},[349,1447,1448],{"class":370},"'\n",[349,1450,1451],{"class":351,"line":374},[349,1452,1453],{"emptyLinePlaceholder":226},"\n",[349,1455,1456],{"class":351,"line":387},[349,1457,1459],{"class":1458},"sHwdD","// 导出 collections\n",[349,1461,1462,1464,1468,1471,1474],{"class":351,"line":402},[349,1463,356],{"class":355},[349,1465,1467],{"class":1466},"spNyl"," const",[349,1469,1470],{"class":366}," collections ",[349,1472,1473],{"class":370},"=",[349,1475,384],{"class":370},[349,1477,1478],{"class":351,"line":423},[34