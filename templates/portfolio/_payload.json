s":231,":loop":231,":width":232,"className":233,"src":235},"true","1000",[234],"rounded-lg","https://res.cloudinary.com/nuxt/video/upload/v1746088224/studio/d53kg6qoo802zy3dzmh0.mp4",[237,238,239,256,259,300],"template-core",{},[240,241,242,249,250,255],"p",{},[243,244,248],"a",{"href":245,"rel":246},"https://ui.nuxt.com/pro",[247],"nofollow","Nuxt UI Pro"," 是一套高级组件集合，是 ",[243,251,254],{"href":252,"rel":253},"https://ui.nuxt.com",[247],"Nuxt UI"," 的扩展，旨在帮助你在几分钟内创建吸引人且响应式的 Nuxt 应用程序。",[240,257,258],{},"Nuxt UI 团队致力于提供最佳的集成和定制体验，而 Studio 团队则提供与 Nuxt Studio 的完全兼容性。",[260,261,262,270,276,282,288,294],"ul",{},[263,264,265,269],"li",{},[266,267,268],"strong",{},"完全可定制","：可以通过你的应用配置更改任何组件的样式，或通过 ui 属性专门定制它们。",[263,271,272,275],{},[266,273,274],{},"轻松编写 Markdown","：Nuxt UI Pro 覆盖了 Nuxt Content 的 prose 组件，使其更加出色，还新增了 Callout、CodeGroup、Field 等组件。",[263,277,278,281],{},[266,279,280],{},"优美的排版样式","：预配置了 Tailwind CSS 排版插件，并根据 Nuxt UI 组件和颜色进行了样式调整。",[263,283,284,287],{},[266,285,286],{},"开箱即用的全文搜索","：Nuxt UI Pro 配备了即用的命令面板组件，无需再配置 Algolia DocSearch。",[263,289,290,293],{},[266,291,292],{},"组件支持插槽","：每个组件都利用了 Vue 插槽的强大功能，给予你构建任何内容的灵活性。",[263,295,296,299],{},[266,297,298],{},"响应式设计","：Nuxt UI Pro 组件旨在结构化你的内容，默认响应式，能适配任何屏幕尺寸。",[301,302,304],"template",{"v-slot:right":303},"",[305,306],"template-features",{":features":307},"[{\"label\":\"Nuxt 3\",\"content\":\"由 Nuxt 3 驱动，提供最佳性能和 SEO。\"},{\"label\":\"Markdown\",\"content\":\"借助 Nuxt Content 使用 MDC 编写页面。\"},{\"label\":\"Nuxt UI\",\"content\":\"提供大量完全可定制的组件。\"},{\"label\":\"TypeScript\",\"content\":\"完全类型化的开发体验。\"},{\"label\":\"Nuxt Studio\",\"content\":\"由 Nuxt Studio 支持，快速更新和预览。\"}]",{"title":303,"searchDepth":309,"depth":309,"links":310},4,[],"main","minimal","https://portfolio-template.nuxt.dev/","一个时尚现代的作品集模板，用于展示你的作品、技能、博客文章、演讲活动，并提供联系信息。","md",null,"nuxt-ui-pro","/templates/portfolio.jpg",{},"portfolio",true,"/templates/portfolio",{"title":217,"description":314},"templates/portfolio","EyLN7xXJBrsvzCPfwmFpn-hm_iaroHl2SB9jjuL7FqA",