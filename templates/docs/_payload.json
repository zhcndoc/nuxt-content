],[227,228,229,246,249,290],"template-core",{},[230,231,232,239,240,245],"p",{},[233,234,238],"a",{"href":235,"rel":236},"https://ui.nuxt.com/pro",[237],"nofollow","Nuxt UI Pro"," 是一组高级组件，作为 ",[233,241,244],{"href":242,"rel":243},"https://ui.nuxt.com",[237],"Nuxt UI"," 的扩展，旨在帮助您在几分钟内创建漂亮且响应式的 Nuxt 应用。",[230,247,248],{},"Nuxt UI 团队致力于提供最佳的集成和定制体验，同时 Studio 团队提供与 Nuxt Studio 的完全兼容性。",[250,251,252,260,266,272,278,284],"ul",{},[253,254,255,259],"li",{},[256,257,258],"strong",{},"完全可定制","：可通过您的应用配置更改任意组件的样式，或通过 ui 属性进行专门定制。",[253,261,262,265],{},[256,263,264],{},"轻松编写 Markdown","：Nuxt UI Pro 重写了 Nuxt Content 的 prose 组件，使其更出色，还新增了 Callout、CodeGroup、Field 等组件。",[253,267,268,271],{},[256,269,270],{},"精美的排版样式","：预配置了 Tailwind CSS 排版插件，样式与 Nuxt UI 组件和颜色匹配。",[253,273,274,277],{},[256,275,276],{},"开箱即用的全文搜索","：Nuxt UI Pro 配备了现成的命令面板组件，无需再配置 Algolia DocSearch。",[253,279,280,283],{},[256,281,282],{},"全面插槽支持","：每个组件都利用 Vue 的插槽功能，给予您构建任意内容的灵活性。",[253,285,286,289],{},[256,287,288],{},"响应式设计","：Nuxt UI Pro 组件旨在构建您的内容结构，天生响应式，适应各种屏幕尺寸。",[291,292,294],"template",{"v-slot:right":293},"",[295,296],"template-features",{":features":297},"[{\"label\":\"Nuxt 3\",\"content\":\"由 Nuxt 3 驱动，带来最佳性能和 SEO。\"},{\"label\":\"Markdown\",\"content\":\"借助 Nuxt Content 使用 MDC 编写页面。\"},{\"label\":\"Nuxt UI\",\"content\":\"提供大量完全可定制的组件。\"},{\"label\":\"TypeScript\",\"content\":\"享受完备的类型化开发体验。\"},{\"label\":\"Nuxt Studio\",\"content\":\"支持 Nuxt Studio，实现快速更新和预览。\"},{\"label\":\"搜索\",\"content\":\"由 Fuse.js 驱动的全文搜索模态框。\"}]",{"title":293,"searchDepth":299,"depth":299,"links":300},2,[],"main","docs","https://v3.docs-template-3erl.pages.dev/","使用此模板，几秒钟内即可创建您的文档。","md","/templates/docs-1.webp","/templates/docs-2.webp","/templates/docs-3.webp","nuxt-ui-pro","/templates/docs.jpg",{"createdAt":312},"2023-11-15T17:41:03.087Z",true,"/templates/docs",{"title":221,"description":304},"templates/docs","I58b2zhqqk27euQdxvxvpkpxp0YU_iyKNBu0_pNO2Qg",1752937488281]