sh__":239},"landing/templates.yml","模板",{"title":230,"description":232},"通过我们量身定制的模板快速启动您的下一个网站。点击即可部署。实时编辑并分享实时预览网址。","yml",{},true,"/templates",{"title":230,"description":232},"templates","nhyuLXeGlpbMLwqC7gcsvx4QOvxnmdoZJT7btPGZ_U0",[241,348,433,613,687,728,803],{"id":242,"title":243,"baseDir":244,"body":245,"branch":331,"category":332,"demo":333,"description":334,"draft":42,"extension":335,"image1":336,"image2":337,"image3":338,"licenseType":339,"mainScreen":340,"meta":341,"name":342,"navigation":235,"owner":343,"path":344,"seo":345,"slug":342,"stem":346,"subtitle":323,"__hash__":347},"templates/templates/canvas.md","画布",".",{"type":246,"value":247,"toc":328},"minimark",[248],[249,250,251,255,320],"template-core",{},[252,253,254],"p",{},"Canvas 作品集是一个完全可定制的国际化作品集模板，使用 Nuxt 和 Nuxt UI 构建，旨在帮助您轻松展示作品、推荐语和关键信息。该模板集成了 Nuxt Studio，提供流畅的编辑体验，同时利用 Nuxt Content 进行内容管理。Canvas 作品集在性能、灵活性和响应式设计方面表现出色，为开发者和创意人员提供了坚实的基础。",[256,257,258,266,272,278,284,290,296,302,308,314],"ul",{},[259,260,261,265],"li",{},[262,263,264],"strong",{},"现代组件与布局"," – 包含内置组件。",[259,267,268,271],{},[262,269,270],{},"Nuxt UI v3"," – 使用预制的可定制 UI 组件。",[259,273,274,277],{},[262,275,276],{},"NuxtHub 支持"," - 几秒钟内部署到 NuxtHub。",[259,279,280,283],{},[262,281,282],{},"Tailwind CSS"," – 美观且响应式的设计系统。",[259,285,286,289],{},[262,287,288],{},"可用的联系表单"," – 集成 Resend，轻松处理邮件。",[259,291,292,295],{},[262,293,294],{},"多语言支持"," – 由 Nuxt i18n 驱动。",[259,297,298,301],{},[262,299,300],{},"SEO 友好"," – 支持 Open Graph 图片（Nuxt OG Image）和 Nuxt Robots，实现自动生成 robots.txt。",[259,303,304,307],{},[262,305,306],{},"良好实践"," – 自动生成网站地图，优化图片（Nuxt Image），以及 ESLint（Nuxt 配置采用 Flat 配置）。",[259,309,310,313],{},[262,311,312],{},"完全响应式"," – 兼容所有现代浏览器和设备。",[259,315,316,319],{},[262,317,318],{},"极简且专业的设计"," – 简洁、优雅且易于定制。",[321,322,324],"template",{"v-slot:right":323},"",[325,326],"template-features",{":features":327},"[{\"label\":\"Nuxt 架构\",\"content\":\"充分利用 Nuxt 3 及其模块生态系统的强大功能。\"},{\"label\":\"支持 Nuxt Studio\",\"content\":\"在 Nuxt Studio 中实时预览并编辑主题内容和外观。\"},{\"label\":\"Vue 组件\",\"content\":\"在内容中插入内置组件（或自己的组件）。\"},{\"label\":\"书写 Markdown\",\"content\":\"享受 Markdown 的简便与轻松，探索 MDC 语法。\"},{\"label\":\"随处部署\",\"content\":\"通过 Studio 一键部署，或在 Vercel、Netlify 零配置部署。可选择静态生成、按需渲染（Node），或 CloudFlare Workers 的边缘渲染。\"},{\"label\":\"可扩展\",\"content\":\"自定义整体设计，或通过插槽添加组件——您可以打造属于自己的 Content-Wind。\"}]",{"title":323,"searchDepth":329,"depth":329,"links":330},2,[],"main","作品集","https://canvas.hrcd.fr/","这是一个支持国际化的完全可定制的作品集模板。","md","/templates/canvas-portfolio-1.png","/templates/canvas-portfolio-2.png","/templates/canvas-portfolio-3.png","free","/templates/canvas.jpg",{},"canvas","HugoRCD","/templates/canvas",{"title":243,"description":334},"templates/canvas","ypy_KMy7JfLzGwAo8Lb0_Wn_hHLWgm0udXIPiv7XzjI",{"id":349,"title":350,"baseDir":244,"body":351,"branch":331,"category":419,"demo":420,"description":421,"draft":42,"extension":335,"image1":422,"image2":423,"image3":424,"licenseType":425,"mainScreen":426,"meta":427,"name":419,"navigation":235,"owner":425,"path":429,"seo":430,"slug":419,"stem":431,"subtitle":323,"__hash__":432},"templates/templates/docs.md","文档",{"type":246,"value":352,"toc":417},[353],[249,354,355,371,374,412],{},[252,356,357,364,365,370],{},[358,359,363],"a",{"href":360,"rel":361},"https://ui.nuxt.com/pro",[362],"nofollow","Nuxt UI Pro"," 是一组高级组件，作为 ",[358,366,369],{"href":367,"rel":368},"https://ui.nuxt.com",[362],"Nuxt UI"," 的扩展，旨在帮助您在几分钟内创建漂亮且响应式的 Nuxt 应用。",[252,372,373],{},"Nuxt UI 团队致力于提供最佳的集成和定制体验，同时 Studio 团队提供与 Nuxt Studio 的完全兼容性。",[256,375,376,382,388,394,400,406],{},[259,377,378,381],{},[262,379,380],{},"完全可定制","：可通过您的应用配置更改任意组件的样式，或通过 ui 属性进行专门定制。",[259,383,384,387],{},[262,385,386],{},"轻松编写 Markdown","：Nuxt UI Pro 重写了 Nuxt Content 的 prose 组件，使其更出色，还新增了 Callout、CodeGroup、Field 等组件。",[259,389,390,393],{},[262,391,392],{},"精美的排版样式","：预配置了 Tailwind CSS 排版插件，样式与 Nuxt UI 组件和颜色匹配。",[259,395,396,399],{},[262,397,398],{},"开箱即用的全文搜索","：Nuxt UI Pro 配备了现成的命令面板组件，无需再配置 Algolia DocSearch。",[259,401,402,405],{},[262,403,404],{},"全面插槽支持","：每个组件都利用 Vue 的插槽功能，给予您构建任意内容的灵活性。",[259,407,408,411],{},[262,409,410],{},"响应式设计","：Nuxt UI Pro 组件旨在构建您的内容结构，天生响应式，适应各种屏幕尺寸。",[321,413,414],{"v-slot:right":323},[325,415],{":features":416},"[{\"label\":\"Nuxt 3\",\"content\":\"由 Nuxt 3 驱动，带来最佳性能和 SEO。\"},{\"label\":\"Markdown\",\"content\":\"借助 Nuxt Content 使用 MDC 编写页面。\"},{\"label\":\"Nuxt UI\",\"content\":\"提供大量完全可定制的组件。\"},{\"label\":\"TypeScript\",\"content\":\"享受完备的类型化开发体验。\"},{\"label\":\"Nuxt Studio\",\"content\":\"支持 Nuxt Studio，实现快速更新和预览。\"},{\"label\":\"搜索\",\"content\":\"由 Fuse.js 驱动的全文搜索模态框。\"}]",{"title":323,"searchDepth":329,"depth":329,"links":418},[],"docs","https://v3.docs-template-3erl.pages.dev/","使用此模板，几秒钟内即可创建您的文档。","/templates/docs-1.webp","/templates/docs-2.webp","/templates/docs-3.webp","nuxt-ui-pro","/templates/docs.jpg",{"createdAt":428},"2023-11-15T17:41:03.087Z","/templates/docs",{"title":350,"description":421},"templates/docs","I58b2zhqqk27euQdxvxvpkpxp0YU_iyKNBu0_pNO2Qg",{"id":434,"title":435,"baseDir":436,"body":437,"branch":331,"category":419,"demo":602,"description":603,"draft":42,"extension":335,"image1":604,"image2":323,"image3":323,"licenseType":425,"mainScreen":605,"meta":606,"name":607,"navigation":235,"owner":608,"path":609,"seo":610,"slug":607,"stem":611,"subtitle":323,"__hash__":612},"templates/templates/docus.md","Docus",".starter",{"type":246,"value":438,"toc":599},[439],[249,440,441,462,465,491,495,498,594],{},[252,442,443,444,449,450,455,456,461],{},"Docus 是一个基于 ",[358,445,448],{"href":446,"rel":447},"https://docs-template.nuxt.dev/",[362],"UI Pro 文档模板"," 的主题。虽然视觉样式开箱即用，但你的重点应放在使用 ",[358,451,454],{"href":452,"rel":453},"https://content.nuxt.com",[362],"Nuxt Content"," 提供的 Markdown 和 ",[358,457,460],{"href":458,"rel":459},"https://content.nuxt.com/docs/files/markdown#mdc-syntax",[362],"MDC 语法"," 来书写内容。",[252,463,464],{},"我们在所有 Nuxt 模块文档中都使用此主题，包括：",[466,467,468,482],"card-group",{},[469,470,475],"card",{"icon":471,"target":472,"title":473,"to":474},"i-simple-icons-nuxtdotjs","_blank","Nuxt Image","https://image.nuxt.com",[252,476,477,481],{},[478,479,480],"code",{},"@nuxt/image"," 的文档",[469,483,486],{"icon":471,"target":472,"title":484,"to":485},"Nuxt Supabase","https://supabase.nuxtjs.org",[252,487,488,481],{},[478,489,490],{},"@nuxt/supabase",[492,493,494],"h2",{"id":494},"主要特点",[252,496,497],{},"此主题包含一系列旨在改善文档管理的功能：",[256,499,500,514,536,553,565,571,576,582,588],{},[259,501,502,505,506,513],{},[262,503,504],{},"基于"," ",[358,507,510],{"href":508,"rel":509},"https://nuxt.com",[362],[262,511,512],{},"Nuxt 3","：利用最新的 Nuxt 框架以实现最佳性能。",[259,515,516,505,519,505,524,505,527,505,532,535],{},[262,517,518],{},"使用",[358,520,522],{"href":367,"rel":521},[362],[262,523,369],{},[262,525,526],{},"和",[358,528,530],{"href":360,"rel":529},[362],[262,531,363],{},[262,533,534],{},"构建","：集成了一整套全面的 UI 组件。",[259,537,538,505,544,505,547,552],{},[358,539,542],{"href":540,"rel":541},"https://content.nuxt.com/usage/markdown",[362],[262,543,460],{},[262,545,546],{},"通过",[358,548,550],{"href":452,"rel":549},[362],[262,551,454],{},"：支持带有组件集成的 Markdown 以实现动态内容。",[259,554,555,505,561,564],{},[358,556,559],{"href":557,"rel":558},"https://content.nuxt.com/docs/studio",[362],[262,560,199],{},[262,562,563],{},"兼容","：以可视化方式编写和编辑内容，无需 Markdown 知识！",[259,566,567,570],{},[262,568,569],{},"自动生成侧边导航","：根据内容结构自动生成导航。",[259,572,573,575],{},[262,574,171],{},"：包含内置搜索功能以便于内容发现。",[259,577,578,581],{},[262,579,580],{},"优化排版","：具有精致的排版以增强可读性。",[259,583,584,587],{},[262,585,586],{},"暗黑模式","：为用户偏好提供暗黑模式支持。",[259,589,590,593],{},[262,591,592],{},"广泛功能","：探索该主题以充分欣赏其能力。",[321,595,596],{"v-slot:right":323},[325,597],{":features":598},"[{\"label\":\"Nuxt 3\",\"content\":\"基于 Nuxt 3，性能与 SEO 表现优异。\"},{\"label\":\"Markdown\",\"content\":\"使用 Nuxt Content 支持的 MDC 编写页面内容。\"},{\"label\":\"Nuxt UI\",\"content\":\"提供大量完全可定制的组件。\"},{\"label\":\"TypeScript\",\"content\":\"完全类型化的开发体验。\"},{\"label\":\"Nuxt Studio\",\"content\":\"兼容 Nuxt Studio，实现快速更新与预览。\"},{\"label\":\"