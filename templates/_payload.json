"id":233,"title":234,"baseDir":235,"body":236,"branch":322,"category":323,"demo":324,"description":325,"draft":42,"extension":326,"image1":327,"image2":328,"image3":329,"licenseType":330,"mainScreen":331,"meta":332,"name":333,"navigation":226,"owner":334,"path":335,"seo":336,"slug":333,"stem":337,"subtitle":314,"__hash__":338},"templates/templates/canvas.md","画布",".",{"type":237,"value":238,"toc":319},"minimark",[239],[240,241,242,246,311],"template-core",{},[243,244,245],"p",{},"Canvas 作品集是一个完全可定制的国际化作品集模板，使用 Nuxt 和 Nuxt UI 构建，旨在帮助您轻松展示作品、推荐语和关键信息。该模板集成了 Nuxt Studio，提供流畅的编辑体验，同时利用 Nuxt Content 进行内容管理。Canvas 作品集在性能、灵活性和响应式设计方面表现出色，为开发者和创意人员提供了坚实的基础。",[247,248,249,257,263,269,275,281,287,293,299,305],"ul",{},[250,251,252,256],"li",{},[253,254,255],"strong",{},"现代组件与布局"," – 包含内置组件。",[250,258,259,262],{},[253,260,261],{},"Nuxt UI v3"," – 使用预制的可定制 UI 组件。",[250,264,265,268],{},[253,266,267],{},"NuxtHub 支持"," - 几秒钟内部署到 NuxtHub。",[250,270,271,274],{},[253,272,273],{},"Tailwind CSS"," – 美观且响应式的设计系统。",[250,276,277,280],{},[253,278,279],{},"可用的联系表单"," – 集成 Resend，轻松处理邮件。",[250,282,283,286],{},[253,284,285],{},"多语言支持"," – 由 Nuxt i18n 驱动。",[250,288,289,292],{},[253,290,291],{},"SEO 友好"," – 支持 Open Graph 图片（Nuxt OG Image）和 Nuxt Robots，实现自动生成 robots.txt。",[250,294,295,298],{},[253,296,297],{},"良好实践"," – 自动生成网站地图，优化图片（Nuxt Image），以及 ESLint（Nuxt 配置采用 Flat 配置）。",[250,300,301,304],{},[253,302,303],{},"完全响应式"," – 兼容所有现代浏览器和设备。",[250,306,307,310],{},[253,308,309],{},"极简且专业的设计"," – 简洁、优雅且易于定制。",[312,313,315],"template",{"v-slot:right":314},"",[316,317],"template-features",{":features":318},"[{\"label\":\"Nuxt 架构\",\"content\":\"充分利用 Nuxt 3 及其模块生态系统的强大功能。\"},{\"label\":\"支持 Nuxt Studio\",\"content\":\"在 Nuxt Studio 中实时预览并编辑主题内容和外观。\"},{\"label\":\"Vue 组件\",\"content\":\"在内容中插入内置组件（或自己的组件）。\"},{\"label\":\"书写 Markdown\",\"content\":\"享受 Markdown 的简便与轻松，探索 MDC 语法。\"},{\"label\":\"随处部署\",\"content\":\"通过 Studio 一键部署，或在 Vercel、Netlify 零配置部署。可选择静态生成、按需渲染（Node），或 CloudFlare Workers 的边缘渲染。\"},{\"label\":\"可扩展\",\"content\":\"自定义整体设计，或通过插槽添加组件——您可以打造属于自己的 Content-Wind。\"}]",{"title":314,"searchDepth":320,"depth":320,"links":321},2,[],"main","作品集","https://canvas.hrcd.fr/","这是一个支持国际化的完全可定制的作品集模板。","md","/templates/canvas-portfolio-1.png","/templates/canvas-portfolio-2.png","/templates/canvas-portfolio-3.png","free","/templates/canvas.jpg",{},"canvas","HugoRCD","/templates/canvas",{"title":234,"description":325},"templates/canvas","ypy_KMy7JfLzGwAo8Lb0_Wn_hHLWgm0udXIPiv7XzjI",{"id":340,"title":341,"baseDir":235,"body":342,"branch":322,"category":410,"demo":411,"description":412,"draft":42,"extension":326,"image1":413,"image2":414,"image3":415,"licenseType":416,"mainScreen":417,"meta":418,"name":410,"navigation":226,"owner":416,"path":420,"seo":421,"slug":410,"stem":422,"subtitle":314,"__hash__":423},"templates/templates/docs.md","文档",{"type":237,"value":343,"toc":408},[344],[240,345,346,362,365,403],{},[243,347,348,355,356,361],{},[349,350,354],"a",{"href":351,"rel":352},"https://ui.nuxt.com/pro",[353],"nofollow","Nuxt UI Pro"," 是一组高级组件，作为 ",[349,357,360],{"href":358,"rel":359},"https://ui.nuxt.com",[353],"Nuxt UI"," 的扩展，旨在帮助您在几分钟内创建漂亮且响应式的 Nuxt 应用。",[243,363,364],{},"Nuxt UI 团队致力于提供最佳的集成和定制体验，同时 Studio 团队提供与 Nuxt Studio 的完全兼容性。",[247,366,367,373,379,385,391,397],{},[250,368,369,372],{},[253,370,371],{},"完全可定制","：可通过您的应用配置更改任意组件的样式，或通过 ui 属性进行专门定制。",[250,374,375,378],{},[253,376,377],{},"轻松编写 Markdown","：Nuxt UI Pro 重写了 Nuxt Content 的 prose 组件，使其更出色，还新增了 Callout、CodeGroup、Field 等组件。",[250,380,381,384],{},[253,382,383],{},"精美的排版样式","：预配置了 Tailwind CSS 排版插件，样式与 Nuxt UI 组件和颜色匹配。",[250,386,387,390],{},[253,388,389],{},"开箱即用的全文搜索","：Nuxt UI Pro 配备了现成的命令面板组件，无需再配置 Algolia DocSearch。",[250,392,393,396],{},[253,394,395],{},"全面插槽支持","：每个组件都利用 Vue 的插槽功能，给予您构建任意内容的灵活性。",[250,398,399,402],{},[253,400,401],{},"响应式设计","：Nuxt UI Pro 组件旨在构建您的内容结构，天生响应式，适应各种屏幕尺寸。",[312,404,405],{"v-slot:right":314},[316,406],{":features":407},"[{\"label\":\"Nuxt 3\",\"content\":\"由 Nuxt 3 驱动，带来最佳性能和 SEO。\"},{\"label\":\"Markdown\",\"content\":\"借助 Nuxt Content 使用 MDC 编写页面。\"},{\"label\":\"Nuxt UI\",\"content\":\"提供大量完全可定制的组件。\"},{\"label\":\"TypeScript\",\"content\":\"享受完备的类型化开发体验。\"},{\"label\":\"Nuxt Studio\",\"content\":\"支持 Nuxt Studio，实现快速更新和预览。\"},{\"label\":\"搜索\",\"content\":\"由 Fuse.js 驱动的全文搜索模态框。\"}]",{"title":314,"searchDepth":320,"depth":320,"links":409},[],"docs","https://v3.docs-template-3erl.pages.dev/","使用此模板，几秒钟内即可创建您的文档。","/templates/docs-1.webp","/templates/docs-2.webp","/templates/docs-3.webp","nuxt-ui-pro","/templates/docs.jpg",{"createdAt":419},"2023-11-15T17:41:03.087Z","/templates/docs",{"title":341,"description":412},"templates/docs","I58b2zhqqk27euQdxvxvpkpxp0YU_iyKNBu0_pNO2Qg",{"id":425,"title":426,"baseDir":427,"body":428,"branch":322,"category":410,"demo":593,"description":594,"draft":42,"extension":326,"image1":595,"image2":314,"image3":314,"licenseType":416,"mainScreen":596,"meta":597,"name":598,"navigation":226,"owner":599,"path":600,"seo":601,"slug":598,"stem":602,"subtitle":314,"__hash__":603},"templates/templates/docus.md","Docus",".starter",{"type":237,"value":429,"toc":590},[430],[240,431,432,453,456,482,486,489,585],{},[243,433,434,435,440,441,446,447,452],{},"Docus 是一个基于 ",[349,436,439],{"href":437,"rel":438},"https://docs-template.nuxt.dev/",[353],"UI Pro 文档模板"," 的主题。虽然视觉样式开箱即用，但你的重点应放在使用 ",[349,442,445],{"href":443,"rel":444},"https://content.nuxt.com",[353],"Nuxt Content"," 提供的 Markdown 和 ",[349,448,451],{"href":449,"rel":450},"https://content.nuxt.com/docs/files/markdown#mdc-syntax",[353],"MDC 语法"," 来书写内容。",[243,454,455],{},"我们在所有 Nuxt 模块文档中都使用此主题，包括：",[457,458,459,473],"card-group",{},[460,461,466],"card",{"icon":462,"target":463,"title":464,"to":465},"i-simple-icons-nuxtdotjs","_blank","Nuxt Image","https://image.nuxt.com",[243,467,468,472],{},[469,470,471],"code",{},"@nuxt/image"," 的文档",[460,474,477],{"icon":462,"target":463,"title":475,"to":476},"Nuxt Supabase","https://supabase.nuxtjs.org",[243,478,479,472],{},[469,480,481],{},"@nuxt/supabase",[483,484,485],"h2",{"id":485},"主要特点",[243,487,488],{},"此主题包含一系列旨在改善文档管理的功能：",[247,490,491,505,527,544,556,562,567,573,579],{},[250,492,493,496,497,504],{},[253,494,495],{},"基于"," ",[349,498,501],{"href":499,"rel":500},"https://nuxt.com",[353],[253,502,503],{},"Nuxt 3","：利用最新的 Nuxt 框架以实现最佳性能。",[250,506,507,496,510,496,515,496,518,496,523,526],{},[253,508,509],{},"使用",[349,511,513],{"href":358,"rel":512},[353],[253,514,360],{},[253,516,517],{},"和",[349,519,521],{"href":351,"rel":520},[353],[253,522,354],{},[253,524,525],{},"构建","：集成了一整套全面的 UI 组件。",[250,528,529,496,535,496,538,543],{},[349,530,533],{"href":531,"rel":532},"https://content.nuxt.com/usage/markdown",[353],[253,534,451],{},[253,536,537],{},"通过",[349,539,541],{"href":443,"rel":540},[353],[253,542,445],{},"：支持带有组件集成的 Markdown 以实现动态内容。",[250,545,546,496,552,555],{},[349,547,550],{"href":548,"rel":549},"https://content.nuxt.com/docs/studio",[353],[253,551,190],{},[253,553,554],{},"兼容","：以可视化方式编写和编辑内容，无需 Markdown 知识！",[250,557,558,561],{},[253,559,560],{},"自动生成侧边导航","：根据内容结构自动生成导航。",[250,563,564,566],{},[253,565,158],{},"：包含内置搜索功能以便于内容发现。",[250,568,569,572],{},[253,570,571],{},"优化排版","：具有精致的排版以增强可读性。",[250,574,575,578],{},[253,576,577],{},"暗黑模式","：为用户偏好提供暗黑模式支持。",[250,580,581,584],{},[253,582,583],{},"广泛功能","：探索该主题以充分欣赏其能力。",[312,586,587],{"v-slot:right":314},[316,588],{":features":589},"[{\"label\":\"Nuxt 3\",\"content\":\"基于 Nuxt 3，性能与 SEO 表现优异。\"},{\"label\":\"Markdown\",\"content\":\"使用 Nuxt Content 支持的 MDC 编写页面内容。\"},{\"label\":\"Nuxt UI\",\"content\":\"提供大量完全可定制的组件。\"},{\"label\":\"TypeScript\",\"content\":\"完全类型化的开发体验。\"},{\"label\":\"Nuxt Studio\",\"content\":\"兼容 Nuxt Studio，实现快速更新与预览。\"},{\"label\":\"Search\",\"content\":\"由 Fuse.js 驱动的全文搜索模态框。\"}]",{"title":314,"searchDepth":320,"depth":320,"links":591},[592],{"id":485,"depth":320,"text":485},"https://docus.dev","用 Markdown 编写美观的文档","/blog/docus.webp","/templates/docus.webp",{"createdAt":419},"docus","nuxtlabs",