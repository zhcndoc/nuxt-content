":323,"image2":324,"image3":325,"licenseType":326,"mainScreen":327,"meta":328,"name":329,"navigation":222,"owner":330,"path":331,"seo":332,"slug":329,"stem":333,"subtitle":310,"__hash__":334},"templates/templates/canvas.md","画布",".",{"type":233,"value":234,"toc":315},"minimark",[235],[236,237,238,242,307],"template-core",{},[239,240,241],"p",{},"Canvas 作品集是一个完全可定制的国际化作品集模板，使用 Nuxt 和 Nuxt UI 构建，旨在帮助您轻松展示作品、推荐语和关键信息。该模板集成了 Nuxt Studio，提供流畅的编辑体验，同时利用 Nuxt Content 进行内容管理。Canvas 作品集在性能、灵活性和响应式设计方面表现出色，为开发者和创意人员提供了坚实的基础。",[243,244,245,253,259,265,271,277,283,289,295,301],"ul",{},[246,247,248,252],"li",{},[249,250,251],"strong",{},"现代组件与布局"," – 包含内置组件。",[246,254,255,258],{},[249,256,257],{},"Nuxt UI v3"," – 使用预制的可定制 UI 组件。",[246,260,261,264],{},[249,262,263],{},"NuxtHub 支持"," - 几秒钟内部署到 NuxtHub。",[246,266,267,270],{},[249,268,269],{},"Tailwind CSS"," – 美观且响应式的设计系统。",[246,272,273,276],{},[249,274,275],{},"可用的联系表单"," – 集成 Resend，轻松处理邮件。",[246,278,279,282],{},[249,280,281],{},"多语言支持"," – 由 Nuxt i18n 驱动。",[246,284,285,288],{},[249,286,287],{},"SEO 友好"," – 支持 Open Graph 图片（Nuxt OG Image）和 Nuxt Robots，实现自动生成 robots.txt。",[246,290,291,294],{},[249,292,293],{},"良好实践"," – 自动生成网站地图，优化图片（Nuxt Image），以及 ESLint（Nuxt 配置采用 Flat 配置）。",[246,296,297,300],{},[249,298,299],{},"完全响应式"," – 兼容所有现代浏览器和设备。",[246,302,303,306],{},[249,304,305],{},"极简且专业的设计"," – 简洁、优雅且易于定制。",[308,309,311],"template",{"v-slot:right":310},"",[312,313],"template-features",{":features":314},"[{\"label\":\"Nuxt 架构\",\"content\":\"充分利用 Nuxt 3 及其模块生态系统的强大功能。\"},{\"label\":\"支持 Nuxt Studio\",\"content\":\"在 Nuxt Studio 中实时预览并编辑主题内容和外观。\"},{\"label\":\"Vue 组件\",\"content\":\"在内容中插入内置组件（或自己的组件）。\"},{\"label\":\"书写 Markdown\",\"content\":\"享受 Markdown 的简便与轻松，探索 MDC 语法。\"},{\"label\":\"随处部署\",\"content\":\"通过 Studio 一键部署，或在 Vercel、Netlify 零配置部署。可选择静态生成、按需渲染（Node），或 CloudFlare Workers 的边缘渲染。\"},{\"label\":\"可扩展\",\"content\":\"自定义整体设计，或通过插槽添加组件——您可以打造属于自己的 Content-Wind。\"}]",{"title":310,"searchDepth":316,"depth":316,"links":317},4,[],"main","作品集","https://canvas.hrcd.fr/","这是一个支持国际化的完全可定制的作品集模板。","md","/templates/canvas-portfolio-1.png","/templates/canvas-portfolio-2.png","/templates/canvas-portfolio-3.png","free","/templates/canvas.jpg",{},"canvas","HugoRCD","/templates/canvas",{"title":230,"description":321},"templates/canvas","6hyqmWf2G33rZLGKW_MkYaGG05-VS-j_u7kQ3trh8o4",{"id":336,"title":337,"baseDir":231,"body":338,"branch":318,"category":406,"demo":407,"description":408,"draft":42,"extension":322,"image1":409,"image2":410,"image3":411,"licenseType":412,"mainScreen":413,"meta":414,"name":406,"navigation":222,"owner":412,"path":416,"seo":417,"slug":406,"stem":418,"subtitle":310,"__hash__":419},"templates/templates/docs.md","文档",{"type":233,"value":339,"toc":404},[340],[236,341,342,358,361,399],{},[239,343,344,351,352,357],{},[345,346,350],"a",{"href":347,"rel":348},"https://ui.nuxt.com/pro",[349],"nofollow","Nuxt UI Pro"," 是一组高级组件，作为 ",[345,353,356],{"href":354,"rel":355},"https://ui.nuxt.com",[349],"Nuxt UI"," 的扩展，旨在帮助您在几分钟内创建漂亮且响应式的 Nuxt 应用。",[239,359,360],{},"Nuxt UI 团队致力于提供最佳的集成和定制体验，同时 Studio 团队提供与 Nuxt Studio 的完全兼容性。",[243,362,363,369,375,381,387,393],{},[246,364,365,368],{},[249,366,367],{},"完全可定制","：可通过您的应用配置更改任意组件的样式，或通过 ui 属性进行专门定制。",[246,370,371,374],{},[249,372,373],{},"轻松编写 Markdown","：Nuxt UI Pro 重写了 Nuxt Content 的 prose 组件，使其更出色，还新增了 Callout、CodeGroup、Field 等组件。",[246,376,377,380],{},[249,378,379],{},"精美的排版样式","：预配置了 Tailwind CSS 排版插件，样式与 Nuxt UI 组件和颜色匹配。",[246,382,383,386],{},[249,384,385],{},"开箱即用的全文搜索","：Nuxt UI Pro 配备了现成的命令面板组件，无需再配置 Algolia DocSearch。",[246,388,389,392],{},[249,390,391],{},"全面插槽支持","：每个组件都利用 Vue 的插槽功能，给予您构建任意内容的灵活性。",[246,394,395,398],{},[249,396,397],{},"响应式设计","：Nuxt UI Pro 组件旨在构建您的内容结构，天生响应式，适应各种屏幕尺寸。",[308,400,401],{"v-slot:right":310},[312,402],{":features":403},"[{\"label\":\"Nuxt 3\",\"content\":\"由 Nuxt 3 驱动，带来最佳性能和 SEO。\"},{\"label\":\"Markdown\",\"content\":\"借助 Nuxt Content 使用 MDC 编写页面。\"},{\"label\":\"Nuxt UI\",\"content\":\"提供大量完全可定制的组件。\"},{\"label\":\"TypeScript\",\"content\":\"享受完备的类型化开发体验。\"},{\"label\":\"Nuxt Studio\",\"content\":\"支持 Nuxt Studio，实现快速更新和预览。\"},{\"label\":\"搜索\",\"content\":\"由 Fuse.js 驱动的全文搜索模态框。\"}]",{"title":310,"searchDepth":316,"depth":316,"links":405},[],"docs","https://v3.docs-template-3erl.pages.dev/","使用此模板，几秒钟内即可创建您的文档。","/templates/docs-1.webp","/templates/docs-2.webp","/templates/docs-3.webp","nuxt-ui-pro","/templates/docs.jpg",{"createdAt":415},"2023-11-15T17:41:03.087Z","/templates/docs",{"title":337,"description":408},"templates/docs","1Ua67yuplLbvN3MuJc6X7HSHDm2dl20UKB99xfEvRq0",{"id":421,"title":422,"baseDir":231,"body":423,"branch":318,"category":484,"demo":485,"description":486,"draft":42,"extension":322,"image1":487,"image2":487,"image3":487,"licenseType":412,"mainScreen":488,"meta":489,"name":422,"navigation":222,"owner":412,"path":490,"seo":491,"slug":492,"stem":493,"subtitle":310,"__hash__":494},"templates/templates/landing.md","登陆页",{"type":233,"value":424,"toc":482},[425,439],[426,427,431],"div",{"className":428},[429,430],"flex","justify-center",[432,433],"video",{":autoplay":434,":controls":434,":loop":434,":width":435,"className":436,"src":438},"true","1000",[437],"rounded-lg","https://res.cloudinary.com/nuxt/video/upload/v1745425967/studio/landing_q03gdo.mp4",[236,440,441,451,454,477],{},[239,442,443,446,447,450],{},[345,444,350],{"href":347,"rel":445},[349]," 是一套高级组件集合，是 ",[345,448,356],{"href":354,"rel":449},[349]," 的扩展，旨在帮助您在几分钟内创建吸引人且响应迅速的 Nuxt 应用程序。",[239,452,453],{},"Nuxt UI 团队致力于提供最佳集成和定制体验，而 Studio 团队则提供与 Nuxt Studio 的完全兼容性。",[243,455,456,466,472],{},[246,457,458,460,461,465],{},[249,459,367],{},"：您可以通过应用配置更改 UI 样式，或通过 ",[462,463,464],"code",{},"index.yml"," 文件编辑您的登陆页内容。",[246,467,468,471],{},[249,469,470],{},"美观的排版样式","：预配置了 Tailwind CSS 排版插件，并且样式与 Nuxt UI 组件和配色相匹配。",[246,473,474,476],{},[249,475,397],{},"：Nuxt UI Pro 组件旨在构建您的内容，它们具有响应式设计，能够适应任何屏幕尺寸。",[308,478,479],{"v-slot:right":310},[312,480],{":features":481},"[{\"label\":\"Nuxt 3\",\"c