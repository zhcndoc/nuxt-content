 & Integrations","/docs/integrations","docs/7.integrations",[156,160],{"title":157,"path":158,"stem":159},"I18n module","/docs/integrations/i18n","docs/7.integrations/01.i18n",{"title":161,"path":162,"stem":163},"LLMs 模块","/docs/integrations/llms","docs/7.integrations/02.llms",{"title":165,"icon":166,"path":167,"stem":168,"children":169,"page":42},"高级用法","i-lucide-code-xml","/docs/advanced","docs/8.advanced",[170,174,178,182,186,190,194],{"title":171,"path":172,"stem":173},"全文搜索","/docs/advanced/fulltext-search","docs/8.advanced/1.fulltext-search",{"title":175,"path":176,"stem":177},"原始内容","/docs/advanced/raw-content","docs/8.advanced/2.raw-content",{"title":179,"path":180,"stem":181},"SQL 存储","/docs/advanced/database","docs/8.advanced/3.database",{"title":183,"path":184,"stem":185},"调试工具","/docs/advanced/tools","docs/8.advanced/4.tools",{"title":187,"path":188,"stem":189},"钩子","/docs/advanced/hooks","docs/8.advanced/5.hooks",{"title":191,"path":192,"stem":193},"自定义来源","/docs/advanced/custom-source","docs/8.advanced/6.custom-source",{"title":195,"path":196,"stem":197},"转换器","/docs/advanced/transformers","docs/8.advanced/8.transformers",{"title":199,"icon":200,"path":201,"stem":202,"children":203,"page":42},"Nuxt Studio","i-lucide-monitor","/docs/studio","docs/9.studio",[204,208,212,216,220,224],{"title":205,"path":206,"stem":207},"设置","/docs/studio/setup","docs/9.studio/1.setup",{"title":209,"path":210,"stem":211},"同步","/docs/studio/github","docs/9.studio/2.github",{"title":213,"path":214,"stem":215},"内容编辑器","/docs/studio/content","docs/9.studio/3.content",{"title":217,"path":218,"stem":219},"媒体库","/docs/studio/medias","docs/9.studio/4.medias",{"title":221,"path":222,"stem":223},"应用配置","/docs/studio/config","docs/9.studio/5.config",{"title":225,"path":226,"stem":227},"本地调试","/docs/studio/debug","docs/9.studio/6.debug",{"id":229,"title":230,"baseDir":231,"body":232,"branch":318,"category":319,"demo":320,"description":321,"draft":42,"extension":322,"image1":323,"image2":324,"image3":325,"licenseType":326,"mainScreen":327,"meta":328,"name":329,"navigation":330,"owner":331,"path":332,"seo":333,"slug":329,"stem":334,"subtitle":310,"__hash__":335},"templates/templates/canvas.md","画布",".",{"type":233,"value":234,"toc":315},"minimark",[235],[236,237,238,242,307],"template-core",{},[239,240,241],"p",{},"Canvas 作品集是一个完全可定制的国际化作品集模板，使用 Nuxt 和 Nuxt UI 构建，旨在帮助您轻松展示作品、推荐语和关键信息。该模板集成了 Nuxt Studio，提供流畅的编辑体验，同时利用 Nuxt Content 进行内容管理。Canvas 作品集在性能、灵活性和响应式设计方面表现出色，为开发者和创意人员提供了坚实的基础。",[243,244,245,253,259,265,271,277,283,289,295,301],"ul",{},[246,247,248,252],"li",{},[249,250,251],"strong",{},"现代组件与布局"," – 包含内置组件。",[246,254,255,258],{},[249,256,257],{},"Nuxt UI v3"," – 使用预制的可定制 UI 组件。",[246,260,261,264],{},[249,262,263],{},"NuxtHub 支持"," - 几秒钟内部署到 NuxtHub。",[246,266,267,270],{},[249,268,269],{},"Tailwind CSS"," – 美观且响应式的设计系统。",[246,272,273,276],{},[249,274,275],{},"可用的联系表单"," – 集成 Resend，轻松处理邮件。",[246,278,279,282],{},[249,280,281],{},"多语言支持"," – 由 Nuxt i18n 驱动。",[246,284,285,288],{},[249,286,287],{},"SEO 友好"," – 支持 Open Graph 图片（Nuxt OG Image）和 Nuxt Robots，实现自动生成 robots.txt。",[246,290,291,294],{},[249,292,293],{},"良好实践"," – 自动生成网站地图，优化图片（Nuxt Image），以及 ESLint（Nuxt 配置采用 Flat 配置）。",[246,296,297,300],{},[249,298,299],{},"完全响应式"," – 兼容所有现代浏览器和设备。",[246,302,303,306],{},[249,304,305],{},"极简且专业的设计"," – 简洁、优雅且易于定制。",[308,309,311],"template",{"v-slot:right":310},"",[312,313],"template-features",{":features":314},"[{\"label\":\"Nuxt 架构\",\"content\":\"充分利用 Nuxt 3 及其模块生态系统的强大功能。\"},{\"label\":\"支持 Nuxt Studio\",\"content\":\"在 Nuxt Studio 中实时预览并编辑主题内容和外观。\"},{\"label\":\"Vue 组件\",\"content\":\"在内容中插入内置组件（或自己的组件）。\"},{\"label\":\"书写 Markdown\",\"content\":\"享受 Markdown 的简便与轻松，探索 MDC 语法。\"},{\"label\":\"随处部署\",\"content\":\"通过 Studio 一键部署，或在 Vercel、Netlify 零配置部署。可选择静态生成、按需渲染（Node），或 CloudFlare Workers 的边缘渲染。\"},{\"label\":\"可扩展\",\"content\":\"自定义整体设计，或通过插槽添加组件——您可以打造属于自己的 Content-Wind。\"}]",{"title":310,"searchDepth":316,"depth":316,"links":317},2,[],"main","作品集","https://canvas.hrcd.fr/","这是一个支持国际化的完全可定制的作品集模板。","md","/templates/canvas-portfolio-1.png","/templates/canvas-portfolio-2.png","/templates/canvas-portfolio-3.png","free","/templates/canvas.jpg",{},"canvas",true,"HugoRCD","/templates/canvas",{"title":230,"description":321},"templates/canvas","ypy_KMy7JfLzGwAo8Lb0_Wn_hHLWgm0udXIPiv7XzjI",1755264985230]