advanced/fulltext-search","docs/7.advanced/1.fulltext-search",{"title":158,"path":159,"stem":160},"原始内容","/docs/advanced/raw-content","docs/7.advanced/2.raw-content",{"title":162,"path":163,"stem":164},"SQL 存储","/docs/advanced/database","docs/7.advanced/3.database",{"title":166,"path":167,"stem":168},"调试工具","/docs/advanced/tools","docs/7.advanced/4.tools",{"title":170,"path":171,"stem":172},"钩子","/docs/advanced/hooks","docs/7.advanced/5.hooks",{"title":174,"path":175,"stem":176},"自定义来源","/docs/advanced/custom-source","docs/7.advanced/6.custom-source",{"title":178,"path":179,"stem":180},"LLM 集成","/docs/advanced/llms","docs/7.advanced/7.llms",{"title":182,"path":183,"stem":184},"转换器","/docs/advanced/transformers","docs/7.advanced/8.transformers",{"title":186,"icon":187,"path":188,"stem":189,"children":190,"page":42},"Nuxt Studio","i-lucide-monitor","/docs/studio","docs/8.studio",[191,195,199,203,207,211],{"title":192,"path":193,"stem":194},"设置","/docs/studio/setup","docs/8.studio/1.setup",{"title":196,"path":197,"stem":198},"同步","/docs/studio/github","docs/8.studio/2.github",{"title":200,"path":201,"stem":202},"内容编辑器","/docs/studio/content","docs/8.studio/3.content",{"title":204,"path":205,"stem":206},"媒体库","/docs/studio/medias","docs/8.studio/4.medias",{"title":208,"path":209,"stem":210},"应用配置","/docs/studio/config","docs/8.studio/5.config",{"title":212,"path":213,"stem":214},"本地调试","/docs/studio/debug","docs/8.studio/6.debug",{"id":216,"title":217,"baseDir":218,"body":219,"branch":305,"category":306,"demo":307,"description":308,"draft":42,"extension":309,"image1":310,"image2":311,"image3":312,"licenseType":313,"mainScreen":314,"meta":315,"name":316,"navigation":317,"owner":318,"path":319,"seo":320,"slug":316,"stem":321,"subtitle":297,"__hash__":322},"templates/templates/canvas.md","画布",".",{"type":220,"value":221,"toc":302},"minimark",[222],[223,224,225,229,294],"template-core",{},[226,227,228],"p",{},"Canvas 作品集是一个完全可定制的国际化作品集模板，使用 Nuxt 和 Nuxt UI 构建，旨在帮助您轻松展示作品、推荐语和关键信息。该模板集成了 Nuxt Studio，提供流畅的编辑体验，同时利用 Nuxt Content 进行内容管理。Canvas 作品集在性能、灵活性和响应式设计方面表现出色，为开发者和创意人员提供了坚实的基础。",[230,231,232,240,246,252,258,264,270,276,282,288],"ul",{},[233,234,235,239],"li",{},[236,237,238],"strong",{},"现代组件与布局"," – 包含内置组件。",[233,241,242,245],{},[236,243,244],{},"Nuxt UI v3"," – 使用预制的可定制 UI 组件。",[233,247,248,251],{},[236,249,250],{},"NuxtHub 支持"," - 几秒钟内部署到 NuxtHub。",[233,253,254,257],{},[236,255,256],{},"Tailwind CSS"," – 美观且响应式的设计系统。",[233,259,260,263],{},[236,261,262],{},"可用的联系表单"," – 集成 Resend，轻松处理邮件。",[233,265,266,269],{},[236,267,268],{},"多语言支持"," – 由 Nuxt i18n 驱动。",[233,271,272,275],{},[236,273,274],{},"SEO 友好"," – 支持 Open Graph 图片（Nuxt OG Image）和 Nuxt Robots，实现自动生成 robots.txt。",[233,277,278,281],{},[236,279,280],{},"良好实践"," – 自动生成网站地图，优化图片（Nuxt Image），以及 ESLint（Nuxt 配置采用 Flat 配置）。",[233,283,284,287],{},[236,285,286],{},"完全响应式"," – 兼容所有现代浏览器和设备。",[233,289,290,293],{},[236,291,292],{},"极简且专业的设计"," – 简洁、优雅且易于定制。",[295,296,298],"template",{"v-slot:right":297},"",[299,300],"template-features",{":features":301},"[{\"label\":\"Nuxt 架构\",\"content\":\"充分利用 Nuxt 3 及其模块生态系统的强大功能。\"},{\"label\":\"支持 Nuxt Studio\",\"content\":\"在 Nuxt Studio 中实时预览并编辑主题内容和外观。\"},{\"label\":\"Vue 组件\",\"content\":\"在内容中插入内置组件（或自己的组件）。\"},{\"label\":\"书写 Markdown\",\"content\":\"享受 Markdown 的简便与轻松，探索 MDC 语法。\"},{\"label\":\"随处部署\",\"content\":\"通过 Studio 一键部署，或在 Vercel、Netlify 零配置部署。可选择静态生成、按需渲染（Node），或 CloudFlare Workers 的边缘渲染。\"},{\"label\":\"可扩展\",\"content\":\"自定义整体设计，或通过插槽添加组件——您可以打造属于自己的 Content-Wind。\"}]",{"title":297,"searchDepth":303,"depth":303,"links":304},4,[],"main","作品集","https://canvas.hrcd.fr/","这是一个支持国际化的完全可定制的作品集模板。","md","/templates/canvas-portfolio-1.png","/templates/canvas-portfolio-2.png","/templates/canvas-portfolio-3.png","free","/templates/canvas.jpg",{},"canvas",true,"HugoRCD","/templates/canvas",{"title":217,"description":308},"templates/canvas","6hyqmWf2G33rZLGKW_MkYaGG05-VS-j_u7kQ3trh8o4",1749797807883]