53],{},"通过",[243,355,357],{"href":252,"rel":356},[247],[305,358,254],{},"：支持带有组件集成的 Markdown 以实现动态内容。",[302,361,362,308,368,371],{},[243,363,366],{"href":364,"rel":365},"https://content.nuxt.com/docs/studio",[247],[305,367,199],{},[305,369,370],{},"兼容","：以可视化方式编写和编辑内容，无需 Markdown 知识！",[302,373,374,377],{},[305,375,376],{},"自动生成侧边导航","：根据内容结构自动生成导航。",[302,379,380,382],{},[305,381,171],{},"：包含内置搜索功能以便于内容发现。",[302,384,385,388],{},[305,386,387],{},"优化排版","：具有精致的排版以增强可读性。",[302,390,391,394],{},[305,392,393],{},"暗黑模式","：为用户偏好提供暗黑模式支持。",[302,396,397,400],{},[305,398,399],{},"广泛功能","：探索该主题以充分欣赏其能力。",[402,403,405],"template",{"v-slot:right":404},"",[406,407],"template-features",{":features":408},"[{\"label\":\"Nuxt 3\",\"content\":\"基于 Nuxt 3，性能与 SEO 表现优异。\"},{\"label\":\"Markdown\",\"content\":\"使用 Nuxt Content 支持的 MDC 编写页面内容。\"},{\"label\":\"Nuxt UI\",\"content\":\"提供大量完全可定制的组件。\"},{\"label\":\"TypeScript\",\"content\":\"完全类型化的开发体验。\"},{\"label\":\"Nuxt Studio\",\"content\":\"兼容 Nuxt Studio，实现快速更新与预览。\"},{\"label\":\"Search\",\"content\":\"由 Fuse.js 驱动的全文搜索模态框。\"}]",{"title":404,"searchDepth":410,"depth":410,"links":411},2,[412],{"id":294,"depth":410,"text":294},"main","docs","https://docus.dev","用 Markdown 编写美观的文档","md","/blog/docus.webp","nuxt-ui-pro","/templates/docus.webp",{"createdAt":422},"2023-11-15T17:41:03.087Z","docus",true,"nuxtlabs","/templates/docus",{"title":230,"description":416},"templates/docus","2PzHxih0gYUWagVMMYlnuakrdEsL9byvKgPhH6PtyxU",1753423281113]