rs.githubusercontent.com/u/2047945?v=4","https://x.com/farnabaz","farnabaz",{"name":233,"avatar":234,"to":236,"username":237},"Sébastien Chopin",{"src":235},"https://avatars.githubusercontent.com/u/904724?v=4","https://x.com/atinux","atinux",{"type":239,"value":240,"toc":1420},"minimark",[241,249,253,258,261,280,292,299,303,321,324,335,339,342,346,349,354,363,368,371,720,726,730,733,757,760,1029,1033,1036,1060,1063,1243,1247,1250,1254,1260,1265,1269,1286,1290,1301,1308,1376,1379,1384,1399,1416],[242,243,245],"h1",{"id":244},"发布-nuxt-content-30",[246,247,248],"strong",{},"发布 Nuxt Content 3.0",[250,251,252],"p",{},"我们非常激动地宣布 Nuxt Content 3.0.0 的首个稳定版本 ✨",[254,255,257],"h2",{"id":256},"性能提升","🚀 性能提升",[250,259,260],{},"Nuxt Content v3 放弃了基于文件的存储方式，转而采用 SQL 数据库系统。使用数据库代替基于文件的存储可减少查询大规模数据集时的许多 I/O 操作。",[262,263,264],"prose-note",{},[250,265,266,267,271,272,275,276,279],{},"全新的数据库系统优化了数据文件的存储和结构方式，确保更佳的性能和可扩展性。此更新完全是幕后进行，不影响您在 Content 中可使用的文件类型（",[268,269,270],"code",{},"yml","、",[268,273,274],{},"json"," 和 ",[268,277,278],{},"markdown","）。",[250,281,282,283,287,288,291],{},"这一切对用户透明，Nuxt Content 依然支持零配置下的开发模式、",[284,285,286],"a",{"href":113},"服务器托管","和",[284,289,290],{"href":145},"静态生成","。",[250,293,294,295,298],{},"此外，现在支持",[284,296,297],{"href":117},"无服务器托管","，客户端导航性能也得到提升。",[300,301,302],"h3",{"id":302},"无服务器兼容性",[250,304,305,306,271,311,315,316,320],{},"Nuxt Content v2 的一个关键挑战是为了存储所有内容文件导致捆绑包体积过大。这在部署到无服务器或边缘平台如 ",[284,307,132],{"href":308,"rel":309},"https://netlify.com",[310],"nofollow",[284,312,120],{"href":313,"rel":314},"https://hub.nuxt.com",[310]," 或 ",[284,317,128],{"href":318,"rel":319},"https://vercel.com",[310]," 时是个问题。",[250,322,323],{},"在无服务器环境中，每个用户请求都会触发 Nuxt 服务器的新实例，每次都是从零开始。此“无状态”特性意味着无法在服务器内存中存储数据，亦不能使用基于文件的数据库如 SQLite。因此，我们实现了数据库适配器，可以独立于你的服务器实例持久化数据。",[262,325,326],{},[250,327,328,329,334],{},"我们会根据你配置中的",[284,330,333],{"href":331,"rel":332},"https://cfec52f9.content-f0q.pages.dev/docs/getting-started/configuration#database",[310],"数据库类型","手动切换到对应的服务提供者（如 Vercel / Postgres，NuxtHub / D1……）。",[300,336,338],{"id":337},"浏览器端的-wasm-sqlite","浏览器端的 WASM SQLite",[250,340,341],{},"对于客户端导航，模块使用类似的方法。当应用执行第一条内容查询时，会从服务器下载生成的转储文件，并在浏览器内初始化本地 SQLite 数据库。从此之后，所有查询都在本地执行，无需再调用服务器：极大提升了应用响应速度，带来无缝的用户体验。",[254,343,345],{"id":344},"️-内容集合","🗄️ 内容集合",[250,347,348],{},"集合是 Nuxt Content 项目中相关内容项的分组。它们帮助更高效地组织和管理大型数据集。",[300,350,352],{"id":351},"定义集合",[246,353,351],{},[250,355,356,357,362],{},"你现在可以在 ",[284,358,359],{"href":17},[268,360,361],{},"content.config.ts"," 文件中定义集合，以配置数据库结构、实用类型以及查找、解析和查询内容的方法。",[300,364,366],{"id":365},"集合模式",[246,367,365],{},[250,369,370],{},"模式确保集合内数据的一致性，并提升 TypeScript 的类型推断，以更好地集成 Nuxt Content 工具。",[372,373,378],"pre",{"className":374,"code":375,"filename":361,"language":376,"meta":377,"style":377},"language-ts shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","import { defineCollection, z } from '@nuxt/content'\n\n// 导出集合\nexport const collections = {\n  // 使用 `defineCollection` 工具定义集合\n  posts: defineCollection({\n    // 指定此集合中的内容类型\n    type: 'page',\n    // 加载匹配此模式的所有文件\n    source: 'blog/**/*.md',\n    // 为此集合定义自定义模式\n    schema: z.object({\n      date: z.date(),\n      image: z.object({\n        src: z.string(),\n        alt: z.string()\n      }),\n      badge: z.object({\n        label: z.string(),\n        color: z.string()\n      })\n    })\n  }),\n}\n","ts","",[268,379,380,419,426,433,452,458,477,483,502,508,525,531,551,571,589,608,625,636,654,672,688,696,704,714],{"__ignoreMap":377},[381,382,385,389,393,397,400,403,406,409,412,416],"span",{"class":383,"line":384},"line",1,[381,386,388],{"class":387},"s7zQu","import",[381,390,392],{"class":391},"sMK4o"," {",[381,394,396],{"class":395},"sTEyZ"," defineCollection",[381,398,399],{"class":391},",",[381,401,402],{"class":395}," z",[381,404,405],{"class":391}," }",[381,407,408],{"class":387}," from",[381,410,411],{"class":391}," '",[381,413,415],{"class":414},"sfazB","@nuxt/content",[381,417,418],{"class":391},"'\