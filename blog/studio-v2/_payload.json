tension":454,"image":455,"meta":457,"navigation":458,"path":459,"seo":460,"stem":461,"__hash__":462},"posts/blog/studio-v2.md","介绍 Nuxt Studio v2",[233],{"name":234,"avatar":235,"to":237,"username":238},"Baptiste Leproux",{"src":236},"https://avatars.githubusercontent.com/u/7290030?v=4","https://x.com/_larbish","larbish",{"type":240,"value":241,"toc":439},"minimark",[242,267,270,286,292,299,306,311,317,328,337,342,345,348,354,359,362,368,371,383,392,395,404,419,423,426,431,436],[243,244,245],"warning",{},[246,247,248,249,256,257,262,263,266],"p",{},"本文发表于 2025 年 1 月 6 日 ",[250,251,255],"a",{"href":252,"rel":253},"https://github.com/nuxt/content",[254],"nofollow","Content"," 和 ",[250,258,261],{"href":259,"rel":260},"https://github.com/nuxtlabs/studio-module",[254],"Studio"," 模块合并之前。因此，内容可能存在一些不一致。Studio 模块现已废弃，作为 Content 模块的可选功能提供。了解如何在",[250,264,265],{"href":6},"此指南","中启用它。",[246,268,269],{},"我们很高兴宣布 Nuxt Studio v2 的发布，这是一次重大更新，带来了全新界面，特别基于用户反馈为用户量身设计。",[271,272,273],"tip",{},[246,274,275,276,280,281,285],{},"Studio 针对 ",[277,278,279],"strong",{},"Nuxt Content"," 项目进行了优化，但唯一真正的要求是拥有包含 Markdown 文件的 ",[282,283,284],"em",{},"content"," 文件夹。这个简单配置足以开始使用该平台编辑和发布文件。",[287,288,290],"h3",{"id":289},"更加直观的界面",[277,291,289],{},[246,293,294],{},[295,296],"img",{"alt":297,"src":298},"Nuxt studio v2 界面","/blog/v2-interface.webp",[246,300,301,302,305],{},"版本 2 的主要改进是对界面的",[277,303,304],{},"全面重构","。我们将其设计得更直观、更易用，尤其对非技术用户更友好。我们的目标是简化用户体验，让创建和设置项目变得更轻松。新界面简洁明快，旨在优化您的工作流程。",[287,307,309],{"id":308},"谷歌认证",[277,310,308],{},[246,312,313],{},[295,314],{"alt":315,"src":316},"谷歌和 GitHub 认证","/blog/google-github.webp",[246,318,319,320,323,324,327],{},"我们现在提供两种不同的认证方式。您可以用 ",[277,321,322],{},"GitHub"," 或 ",[277,325,326],{},"Google"," 登录。这两种方式赋予相同的编辑权限，但由于 Studio 与 GitHub 同步，部分功能专属 GitHub 用户，尤其是项目创建。",[243,329,330],{},[246,331,332,333,336],{},"由于 Google 用户无法创建项目，需",[277,334,335],{},"加入已有项目的团队","以进行编辑。",[287,338,340],{"id":339},"最简配置即可编辑文件",[277,341,339],{},[246,343,344],{},"您现在无需任何配置即可编辑内容，只需导入您的仓库即可。您可以浏览文件和媒体，编辑内容并发布到 GitHub。",[246,346,347],{},"团队协作功能也已支持。",[246,349,350],{},[295,351],{"alt":352,"src":353},"类 Notion 编辑器支持协作","/blog/collaborate.webp",[243,355,356],{},[246,357,358],{},"编辑器中的媒体在未设置实时预览前不会显示（详见下文）。",[287,360,361],{"id":361},"简化的实时预览设置",[246,363,364],{},[295,365],{"alt":366,"src":367},"实时预览开启于类 Notion 编辑器与网站之间","/blog/preview.webp",[246,369,370],{},"由于实时预览功能需要部署的 URL，我们使设置尽可能简单。",[246,372,373,374,379,380],{},"虽然 GitHub Pages 部署依然可用且无需您配置，但自托管项目的要求已简化，移除了令牌校验。",[250,375,378],{"href":376,"rel":377},"https://nuxt.studio/docs/get-started/setup#enable-the-live-preview",[254],"启用 Studio 模块"," 是",[277,381,382],{},"唯一剩下的要求。",[243,384,385],{"to":259},[246,386,387,388,391],{},"务必使用最新版本的 ",[277,389,390],{},"Studio 模块"," 以确保兼容性及访问新功能。",[287,393,394],{"id":394},"全新的文档",[246,396,397,398,403],{},"随着全新平台上线，带来了",[250,399,402],{"href":400,"rel":401},"https://nuxt.studio/docs/get-started/introduction",[254],"新文档","。欢迎查阅，深入了解全新的 Studio。",[246,405,406,407,412,413,418],{},"无论您是",[250,408,411],{"href":409,"rel":410},"https://nuxt.studio/docs/editors/introduction",[254],"编辑者","还是",[250,414,417],{"href":415,"rel":416},"https://nuxt.studio/docs/developers/introduction",[254],"开发者","，现在都有专属的文档章节。",[287,420,422],{"id":421},"studio-的新方向","Studio 的新方向",[246,424,425],{},"大多数可用 CMS 解决方案要么面向开发者提供高度可定制化，要么面向内容编辑者非常友好，Studio 希望兼顾二者。",[246,427,428],{},[277,429,430],{},"开发者提供工具，使编辑者专注内容，无需任何技术知识。",[271,432,433],{},[246,434,435],{},"我们的类 Notion 编辑器前景广阔，期待与社区共同发展。",[287,437],{"id":438},"",{"title":438,"searchDepth":440,"depth":440,"links":441},2,[442,444,445,446,447,448,449],{"id":289,"depth":443,"text":289},3,{"id":308,"depth":443,"text":308},{"id":339,"depth":443,"text":339},{"id":361,"depth":443,"text":361},{"id":394,"depth":443,"text":394},{"id":421,"depth":443,"text":422},{"id":438,"depth":443,"text":438},null,"studio","2024-06-13T00:00:00.000Z","我们很高兴地宣布 Nuxt Studio v2 的发布，这是为您的 Nuxt Content 网站带来全新编辑体验的大版本更新","md",{"src":456},"/blog/nuxt-studio-v2.png",{},true,"/blog/studio-v2",{"title":231,"description":453},"blog/studio-v2","sE9xukpgxjfcbOtMbib4_PeQr5D0rG4i68Ay675C7Q0",[464,450],{"title":465,"path":466,"stem":467,"description":468,"children":-1},"Nuxt Studio 可视化编辑器幕后揭秘","/blog/visual-editor","blog/visual-editor","探索 Nuxt Studio 可视化编辑器的内部工作原理，以及它如何解析 Markdown 语法并重新生成内容。",1753423281502]