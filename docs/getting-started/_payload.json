tle":154,"path":155,"stem":156},"全文搜索","/docs/advanced/fulltext-search","docs/7.advanced/1.fulltext-search",{"title":158,"path":159,"stem":160},"原始内容","/docs/advanced/raw-content","docs/7.advanced/2.raw-content",{"title":162,"path":163,"stem":164},"SQL 存储","/docs/advanced/database","docs/7.advanced/3.database",{"title":166,"path":167,"stem":168},"调试工具","/docs/advanced/tools","docs/7.advanced/4.tools",{"title":170,"path":171,"stem":172},"钩子","/docs/advanced/hooks","docs/7.advanced/5.hooks",{"title":174,"path":175,"stem":176},"自定义来源","/docs/advanced/custom-source","docs/7.advanced/6.custom-source",{"title":178,"path":179,"stem":180},"LLM 集成","/docs/advanced/llms","docs/7.advanced/7.llms",{"title":182,"path":183,"stem":184},"转换器","/docs/advanced/transformers","docs/7.advanced/8.transformers",{"title":186,"icon":187,"path":188,"stem":189,"children":190,"page":42},"Nuxt Studio","i-lucide-monitor","/docs/studio","docs/8.studio",[191,195,199,203,207,211],{"title":192,"path":193,"stem":194},"设置","/docs/studio/setup","docs/8.studio/1.setup",{"title":196,"path":197,"stem":198},"同步","/docs/studio/github","docs/8.studio/2.github",{"title":200,"path":201,"stem":202},"内容编辑器","/docs/studio/content","docs/8.studio/3.content",{"title":204,"path":205,"stem":206},"媒体库","/docs/studio/medias","docs/8.studio/4.medias",{"title":208,"path":209,"stem":210},"应用配置","/docs/studio/config","docs/8.studio/5.config",{"title":212,"path":213,"stem":214},"本地调试","/docs/studio/debug","docs/8.studio/6.debug",{"page":216,"surround":409},{"id":217,"title":218,"body":219,"description":402,"extension":403,"links":404,"meta":405,"navigation":406,"path":6,"seo":407,"stem":7,"__hash__":408},"docs/docs/1.getting-started/1.index.md","Nuxt Content v3",{"type":220,"value":221,"toc":388},"minimark",[222,226,230,234,237,286,292,295,298,301,319,322,343,347,350,359,371,374,377,381],[223,224,225],"p",{},"欢迎使用 Nuxt Content v3，这是一次重大升级，为您的 Nuxt 项目带来更高性能和创新功能。我们基于 Git 的 CMS 的最新版本针对现代应用开发进行了优化。",[227,228,229],"h2",{"id":229},"新功能",[231,232,233],"h3",{"id":233},"内容集合",[223,235,236],{},"集合用于组织项目中的相关项，帮助您更高效地管理大型数据集。主要优势包括：",[238,239,240,257,263,269,275],"ul",{},[241,242,243,247,248,256],"li",{},[244,245,246],"strong",{},"结构化数据","：在 ",[249,250,252],"a",{"href":251},"/docs/collections/define#defining-collections",[253,254,255],"code",{},"content.config.ts"," 中配置数据库架构并定义集合",[241,258,259,262],{},[244,260,261],{},"类型安全查询","：所有工具均支持 TypeScript 直接集成",[241,264,265,268],{},[244,266,267],{},"自动验证","：确保 Frontmatter 字段和数据文件（json、yml 等）的一致性",[241,270,271,274],{},[244,272,273],{},"高级查询构建器","：轻松过滤、排序和分页集合数据",[241,276,277,280,281,285],{},[244,278,279],{},"Studio 集成","：通过 ",[249,282,284],{"href":283},"/studio","Studio"," 实现更好的表单生成和优化的编辑体验",[223,287,288,289,291],{},"了解更多关于",[249,290,233],{"href":32},"的信息。",[231,293,294],{"id":294},"性能提升",[223,296,297],{},"v2 中的一个主要挑战是用于存储文件的大体积包，特别影响无服务器部署。",[223,299,300],{},"v3 通过在生产环境中切换到基于 SQL 的存储解决了这一问题。此转换无需任何配置，支持开发模式、静态生成、服务器托管、无服务器和边缘部署。",[302,303,304],"prose-note",{},[223,305,306,307,310,311,314,315,318],{},"新的数据库系统改进了数据文件的存储和结构方式，确保更佳的性能和可扩展性。此更新全部在后台完成，不影响您在 Content 中使用的文件类型（",[253,308,309],{},"yml","、",[253,312,313],{},"json"," 和 ",[253,316,317],{},"markdown","）。",[223,320,321],{},"优势包括：",[238,323,324,330],{},[241,325,326,329],{},[244,327,328],{},"优化的查询","：SQL 存储实现超高速数据检索",[241,331,332,335,336,310,338,314,340,342],{},[244,333,334],{},"通用兼容性","：我们的基于适配器的系统可整合 SQL 数据库，支持所有部署模式（",[249,337,112],{"href":113},[249,339,116],{"href":117},[249,341,144],{"href":145},"）。我们欢迎社区贡献更多适配器。",[231,344,346],{"id":345},"typescript-集成","TypeScript 集成",[223,348,349],{},"新的集合系统为您的所有数据自动生成 TypeScript 类型。所有工具和 API 都基于您的集合定义强类型，确保开发过程中的类型安全。",[231,351,353,354],{"id":352},"nuxt-studio-集成-即将推出","Nuxt Studio 集成 ",[355,356,358],"badge",{"color":357},"neutral","即将推出",[223,360,361,363,364,370],{},[249,362,186],{"href":193}," 与 v3 设计上完美互补。",[249,365,369],{"href":366,"rel":367},"https://github.com/nuxtlabs/studio-module",[368],"nofollow","studio 模块","现已直接集成到 Nuxt Content 中，打造理想环境，开发者专注编码，团队成员则通过直观界面管理内容。",[372,373],"hr",{},[223,375,376],{},"我们很高兴您能探索这些新功能。深入阅读文档，了解如何集成该模块并在您的下一个项目中实践最佳方案。",[227,378,380],{"id":379},"content-v2-迁移","Content V2 迁移",[223,382,383,384,387],{},"了解如何从 Content v2 迁移到 v3，请参见",[249,385,386],{"href":21},"迁移指南","。",{"title":389,"searchDepth":390,"depth":390,"links":391},"",4,[392,401],{"id":229,"depth":393,"text":229,"children":394},2,[395,397,398,399],{"id":233,"depth":396,"text":233},3,{"id":294,"depth":396,"text":294},{"id":345,"depth":396,"text":346},{"id":352,"depth":396,"text":400},"Nuxt Studio 集成 即将推出",{"id":379,"depth":393,"text":380},"专为 Nuxt 开发者设计的强大基于 Git 的 CMS。","md",null,{},{"title":10},{"title":218,"description":402},"9-rh1P5QvFW1BLRcVgmQHs8hrzGDVQ3AE4cG-EA3ftc",[404,410],{"title":12,"path":13,"stem":14,"description":411,"children":-1},"在你的 Nuxt 应用中开始使用 Nuxt Content v3。",{"data":413,"body":414},{},{"type":415,"children":416},"root",[417],{"type":418,"tag":223,"props":419,"children":420},"element",{},[421],{"type":422,"value":402},"text",1749797806508]