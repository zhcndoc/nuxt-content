:206,"seo":783,"stem":207,"__hash__":786},"docs/docs/9.studio/1.setup.md","设置 Nuxt Studio",{"type":232,"value":233,"toc":771},"minimark",[234,238,255,258,264,268,282,288,292,295,306,313,316,322,325,330,367,372,381,476,486,490,501,767],[235,236,237],"p",{},"Studio 是一个直观的 CMS 界面，用于编辑你的 Nuxt Content 网站。",[235,239,240,241,245,246,248,249,251,252,254],{},"它利用 Nuxt Content 内置的 ",[242,243,244],"code",{},"Preview API","，为内容文件提供最佳编辑体验。编辑者可以通过用户友好的界面编辑他们的 ",[242,247,50],{},"、",[242,250,54],{}," 或 ",[242,253,58],{}," 文件。",[235,256,257],{},"开发者可以自定义编辑体验并为编辑者提供工具，使编辑者能够专注于内容，无需任何技术专长。",[259,260],"video",{":autoplay":261,":controls":261,":loop":261,"poster":262,"src":263},"true","/home/videos/HomeNotionLikePoster.webp","https://res.cloudinary.com/nuxt/video/upload/v1733494722/contentv3final_rc8bvu.mp4",[265,266,267],"h2",{"id":267},"认证",[235,269,270,271,278,279,281],{},"Studio 管理后台位于 ",[272,273,277],"a",{"href":274,"rel":275},"https://nuxt.studio",[276],"nofollow","nuxt.studio","。你可以通过 GitHub 或 Google 登录。两种方式会赋予相同的编辑权限，但由于 Studio 与 GitHub ",[272,280,209],{"href":210},"，仓库导入必须由 GitHub 用户操作。",[283,284,285],"warning",{},[235,286,287],{},"Google 认证适用于非技术用户。Google 用户必须加入已有项目的团队才能进行编辑。",[265,289,291],{"id":290},"连接你的-nuxt-content-仓库","连接你的 Nuxt Content 仓库",[235,293,294],{},"登录管理后台后，你可以直接从界面导入你的 Nuxt Content 仓库。",[296,297,298],"tip",{},[235,299,300,301,305],{},"有两种选择，你可以导入一个已有的仓库，或使用我们的 ",[272,302,304],{"href":303},"/templates","模板","。",[235,307,308,309,312],{},"唯一的要求是你的仓库必须托管在 GitHub 上。通过界面连接我们的 ",[272,310,311],{"href":210},"GitHub 应用","，然后即可将 GitHub 仓库链接到你的 Studio 项目中。",[235,314,315],{},"项目创建成功后，你就可以使用 Studio 的编辑器开始编辑文件，并发布你的更改。",[265,317,319],{"id":318},"启用完整编辑体验",[320,321,318],"strong",{},[235,323,324],{},"要解锁 Studio 的全部功能，请确保你的项目 URL 在部署部分正确配置。",[235,326,327],{},[320,328,329],{},"这将启用所有 Studio 功能，包括：",[331,332,333,340,349,359],"ul",{},[334,335,336,339],"li",{},[320,337,338],{},"网站实时预览："," 在编辑时立即在网站上看到更改效果。",[334,341,342,345,346,348],{},[320,343,344],{},"动态表单生成："," 根据你的 Nuxt Content ",[272,347,25],{"href":32},"自动生成编辑表单。",[334,350,351,354,355,305],{},[320,352,353],{},"增强的 Markdown 编辑器："," 提供更好的编辑体验，包括列出和集成你已暴露的 ",[272,356,358],{"href":357},"/docs/studio/content#vue-components","Vue 组件",[334,360,361,364,365,305],{},[320,362,363],{},"自动应用配置："," 根据你定义的 schema 生成 ",[272,366,221],{"href":222},[296,368,369],{},[235,370,371],{},"我们提供了 GitHub Pages 部署方案，使用它可以帮你处理所有要求。如果你想使用自己选择的部署平台，请参照以下简单指南。",[235,373,374,375,378,379,305],{},"要在 Studio 中设置你的 URL，只需在 ",[242,376,377],{},"nuxt.config.ts"," 文件的内容配置中设置 ",[242,380,244],{},[382,383,388],"pre",{"className":384,"code":385,"filename":377,"language":386,"meta":387,"style":387},"language-ts shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","export default defineNuxtConfig({\n  content: {\n    preview: {\n      api: 'https://api.nuxt.studio'\n    }\n  }\n})\n","ts","",[242,389,390,414,427,437,455,461,467],{"__ignoreMap":387},[391,392,395,399,402,406,410],"span",{"class":393,"line":394},"line",1,[391,396,398],{"class":397},"s7zQu","export",[391,400,401],{"class":397}," default",[391,403,405],{"class":404},"s2Zo4"," defineNuxtConfig",[391,407,409],{"class":408},"sTEyZ","(",[391,411,413],{"class":412},"sMK4o","{\n",[391,415,417,421,424],{"class":393,"line":416},2,[391,418,420],{"class":419},"swJcz","  content",[391,422,423],{"class":412},":",[391,425,426],{"class":412}," {\n",[391,428,430,433,435],{"class":393,"line":429},3,[391,431,432],{"class":419},"    preview",[391,434,423],{"class":412},[391,436,426],{"class":412},[391,438,440,443,445,448,452],{"class":393,"line":439},4,[391,441,442],{"class":419},"      api",[391,444,423],{"class":412},[391,446,447],{"class":412}," '",[391,449,451],{"class":450},"sfazB","https://api.nuxt.studio",[391,453,454],{"class":412},"'\n",[391,456,458],{"class":393,"line":457},5,[391,459,460],{"class":412},"    }\n",[391,462,464],{"class":393,"line":463},6,[391,465,466],{"class":412},"  }\n",[391,468,470,473],{"class":393,"line":469},7,[391,471,472],{"c