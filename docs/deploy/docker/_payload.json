30,232],"h2",{"id":231},"使用-nodejs-镜像","使用 Node.js 镜像",[225,234,235],{},"使用 Docker 的 Node.js 镜像，您可以部署您的内容应用。您只需要创建一个 Dockerfile 并构建镜像。以下是一个示例 Dockerfile：",[237,238,244],"pre",{"className":239,"code":240,"filename":241,"language":242,"meta":243,"style":243},"language-docker shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","# 构建阶段 1\n\nFROM node:22-alpine AS build\nWORKDIR /app\n\nRUN corepack enable\n\n# 复制 package.json 和您的锁文件，这里添加 pnpm-lock.yaml 作为示例\nCOPY package.json pnpm-lock.yaml .npmrc ./\n\n# 安装依赖\nRUN pnpm i\n\n# 复制整个项目\nCOPY . ./\n\n# 构建项目\nRUN pnpm run build\n\n# 构建阶段 2\n\nFROM node:22-alpine\nWORKDIR /app\n\n# 只需要从构建阶段复制 `.output` 文件夹\nCOPY --from=build /app/.output/ ./\n\n# 修改端口和主机\nENV PORT=80\nENV HOST=0.0.0.0\n\nEXPOSE 80\n\nCMD [\"node\", \"/app/server/index.mjs\"]\n","Dockerfile","docker","",[245,246,247,256,263,280,289,294,303,308,314,323,328,334,342,347,353,361,366,372,380,385,391,396,404,411,416,422,430,435,441,450,458,463,472,477],"code",{"__ignoreMap":243},[248,249,252],"span",{"class":250,"line":251},"line",1,[248,253,255],{"class":254},"sHwdD","# 构建阶段 1\n",[248,257,259],{"class":250,"line":258},2,[248,260,262],{"emptyLinePlaceholder":261},true,"\n",[248,264,266,270,274,277],{"class":250,"line":265},3,[248,267,269],{"class":268},"sbssI","FROM",[248,271,273],{"class":272},"sTEyZ"," node:22-alpine ",[248,275,276],{"class":268},"AS",[248,278,279],{"class":272}," build\n",[248,281,283,286],{"class":250,"line":282},4,[248,284,285],{"class":268},"WORKDIR",[248,287,288],{"class":272}," /app\n",[248,290,292],{"class":250,"line":291},5,[248,293,262],{"emptyLinePlaceholder":261},[248,295,297,300],{"class":250,"line":296},6,[248,298,299],{"class":268},"RUN",[248,301,302],{"class":272}," corepack enable\n",[248,304,306],{"class":250,"line":305},7,[248,307,262],{"emptyLinePlaceholder":261},[248,309,311],{"class":250,"line":310},8,[248,312,313],{"class":254},"# 复制 package.json 和您的锁文件，这里添加 pnpm-lock.yaml 作为示例\n",[248,315,317,