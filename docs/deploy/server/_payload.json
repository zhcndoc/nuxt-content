/server/index.mjs"," 来运行它。",[223,237,238],{"id":238},"环境要求",[228,240,241,242,245],{},"如果你使用默认的 ",[232,243,244],{},"better-sqlite3"," 模块来操作 sqlite 数据库，则必须部署在 Glibc 版本高于 2.29 的操作系统上，例如 Debian 11、Ubuntu 20.04。",[247,248,249],"note",{},[228,250,251,252,255,256,263],{},"你可以使用 ",[232,253,254],{},"ldd --version"," 检查 Glibc 版本。更多信息请参见 ",[257,258,262],"a",{"href":259,"rel":260},"https://github.com/nuxt/content/issues/3248",[261],"nofollow","issue #3248","。",[223,265,267],{"id":266},"使用-nodejs-预设构建","使用 Node.js 预设构建",[228,269,270],{},"使用 Nuxt 构建命令构建项目：",[272,273,279],"pre",{"className":274,"code":275,"filename":276,"language":277,"meta":278,"style":278},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","nuxi build\n","Terminal","bash","",[232,280,281],{"__ignoreMap":278},[282,283,286,290],"span",{"class":284,"line":285},"line",1,[282,287,289],{"class":288},"sBMFI","nuxi",[282,291,293],{"class":292},"sfazB"," build\n",[228,295,296,297,300],{},"使用 Node 服务器预设运行 ",[232,298,299],{},"nuxi build"," 后，结果将是一个启动可运行 Node 服务器的入口点。",[272,302,304],{"className":274,"code":303,"filename":276,"language":277,"meta":278,"style":278},"$ node .output/server/index.mjs\nListening on http://localhost:3000\n",[232,305,306,317],{"__ignoreMap":278},[282,307,308,311,314],{"class":284,"line":285},[282,309,310],{"class":288},"$",[282,312,313],{"class":292}," node",[282,315,316],{"class":292}," .output/server/index.mjs\n",[282,318,320,323,326],{"class":284,"line":319},2,[282,321,322],{"class":288},"Listening",[282,324,325],{"class":292}," on",[282,327,328],{"class":292}," http://localhost:3000\n",[247,330,331],{},[228,332,333],{},"SQLite 数据库将在服务器启动时在服务器端加载，同时在浏览器中用于客户端导航或操作。",[335,336,337],"style",{},"html pre.shiki code .sBMFI, html code.shiki .sBMFI{--shiki-light:#E2931D;--shiki-default:#FFCB6B;--shiki-dark:#FFCB6B}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html .light .shiki span {c