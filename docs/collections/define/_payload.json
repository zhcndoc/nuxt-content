gation":1313,"path":32,"seo":1314,"stem":33,"__hash__":1315},"docs/docs/2.collections/1.define.md","定义内容集合",{"type":232,"value":233,"toc":1301},"minimark",[234,243,250,259,264,267,270,305,308,314,317,487,507,512,515,530,741,759,765,768,776,1036,1045,1049,1055,1176,1181,1289,1294,1297],[235,236,237,238,242],"p",{},"Nuxt Content 模块会自动解析位于 Nuxt 应用根目录下 ",[239,240,241],"code",{},"content/"," 文件夹中的所有内容文件。此设置允许你自由地组织文件夹结构，以满足项目需求。",[235,244,245,246,249],{},"为了更好地组织内容，你可以使用内容集合 (Content Collections)，它们帮助你更有效地分类和管理内容。这些集合在 ",[239,247,248],{},"content.config.ts"," 文件中定义。",[251,252,253],"warning",{},[235,254,255,256,258],{},"如果没有 ",[239,257,248],{}," 文件，内容文件夹中的所有文件都会被默认解析和导入。但一旦添加了配置文件，只有符合集合中指定路径模式的文件才会被导入。",[260,261,263],"h2",{"id":262},"什么是内容集合","什么是内容集合？",[235,265,266],{},"内容集合是 Nuxt Content 项目中组织相关内容的方式。它们提供了一种结构化方法来管理内容，使查询、展示和维护网站数据更加便捷。",[235,268,269],{},"关键特性包括：",[271,272,273,281,287,293,299],"ul",{},[274,275,276,280],"li",{},[277,278,279],"strong",{},"逻辑分组","：将相似内容归为一类，如博客文章、产品页面或文档",[274,282,283,286],{},[277,284,285],{},"共享配置","：对集合内所有条目应用通用设置和验证",[274,288,289,292],{},[277,290,291],{},"优化查询","：高效获取和筛选相关内容项",[274,294,295,298],{},[277,296,297],{},"自动类型推断","：在开发环境中获得类型安全和自动补全",[274,300,301,304],{},[277,302,303],{},"灵活结构","：按内容类型、类别或任何适合你的逻辑分组组织集合",[260,306,307],{"id":307},"定义集合",[235,309,310,311,313],{},"在项目根目录创建一个 ",[239,312,248],{}," 文件。这个特殊文件用于配置你的集合数据库、工具类型和内容处理。",[235,315,316],{},"以下是一个基础示例：",[318,319,324],"pre",{"className":320,"code":321,"filename":248,"language":322,"meta":323,"style":323},"language-ts shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","import { defineCollection, defineContentConfig } from '@nuxt/content'\n\nexport default defineContentConfig({\n  collections: {\n    docs: defineCollection({\n      // 加载 `content` 目录下的所有文件\n      source: '**',\n      // 指定此集合内容类型\n      type: 'page'\n    })\n  }\n})\n","ts","",[239,325,326,365,372,390,403,417,424,443,449,464,473,479],{"__ignoreMap":323},[327,328,331,335,339,343,3