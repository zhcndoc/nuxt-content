code",{},"content/"," 文件夹中的所有内容文件。此设置允许你自由地组织文件夹结构，以满足项目需求。",[223,232,233,234,237],{},"为了更好地组织内容，你可以使用内容集合 (Content Collections)，它们帮助你更有效地分类和管理内容。这些集合在 ",[227,235,236],{},"content.config.ts"," 文件中定义。",[239,240,241],"warning",{},[223,242,243,244,246],{},"如果没有 ",[227,245,236],{}," 文件，内容文件夹中的所有文件都会被默认解析和导入。但一旦添加了配置文件，只有符合集合中指定路径模式的文件才会被导入。",[248,249,251],"h2",{"id":250},"什么是内容集合","什么是内容集合？",[223,253,254],{},"内容集合是 Nuxt Content 项目中组织相关内容的方式。它们提供了一种结构化方法来管理内容，使查询、展示和维护网站数据更加便捷。",[223,256,257],{},"关键特性包括：",[259,260,261,269,275,281,287],"ul",{},[262,263,264,268],"li",{},[265,266,267],"strong",{},"逻辑分组","：将相似内容归为一类，如博客文章、产品页面或文档",[262,270,271,274],{},[265,272,273],{},"共享配置","：对集合内所有条目应用通用设置和验证",[262,276,277,280],{},[265,278,279],{},"优化查询","：高效获取和筛选相关内容项",[262,282,283,286],{},[265,284,285],{},"自动类型推断","：在开发环境中获得类型安全和自动补全",[262,288,289,292],{},[265,290,291],{},"灵活结构","：按内容类型、类别或任何适合你的逻辑分组组织集合",[248,294,295],{"id":295},"定义集合",[223,297,298,299,301],{},"在项目根目录创建一个 ",[227,300,236],{}," 文件。这个特殊文件用于配置你的集合数据库、工具类型和内容处理。",[223,303,304],{},"以下是一个基础示例：",[306,307,312],"pre",{"className":308,"code":309,"filename":236,"language":310,"meta":311,"style":311},"language-ts shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","import { defineCollection, defineContentConfig } from '@nuxt/content'\n\nexport default defineContentConfig({\n  collections: {\n    docs: defineCollection({\n      // 加载 `content` 目录下的所有文件\n      source: '**',\n      // 指定此集合内容类型\n      type: 'page'\n    })\n  }\n})\n","ts","",[227,313,314,353,360,378,391,405,412,431,437,452,461,467],{"__ignoreMap":311},[315,316,319,323,327,331,334,337,340,343,346,350],"span",{"class":317,"line":318},"line",1,[315,320,322],{"class":321},"s7zQu","import",[315,324,326],{"class":325},"sMK4o"," {",[315,328,330],{"class":329},"sTEyZ"," defineCollection",[315,332,333],{"class":325},",",[315,335,336],{"class":329}," defineContentConfig",[315,338,339],{"class":325}," }",[315,341,342],{"class":321}," from",[315,344,