使用 ",[230,484,485],{},"exclude"," 属性，通过合适的正则表达式显式排除文档在其他集合中出现。",[226,488,489,490,497],{},"该话题仍在此 issue 中讨论中：",[491,492,496],"a",{"href":493,"rel":494},"https://github.com/nuxt/content/issues/2966",[495],"nofollow","nuxt/content#2966","。",[499,500,502],"h3",{"id":501},"集合模式-schema","集合模式 (Schema)",[226,504,505],{},"模式用于强制集合内数据的一致性，并作为 TypeScript 类型的唯一来源。",[226,507,508,509,512,513,520],{},"除内置字段外，你还可以通过为集合添加 ",[230,510,511],{},"schema"," 属性，利用 ",[491,514,517],{"href":515,"rel":516},"https://zod.dev",[495],[230,518,519],{},"zod"," 模式定义自定义模式：",[309,522,524],{"className":311,"code":523,"filename":239,"language":313,"meta":314,"style":314},"import { defineCollection, defineContentConfig, z } from '@nuxt/content'\n\nexport default defineContentConfig({\n  collections: {\n    blog: defineCollection({\n      source: 'blog/*.md',\n      type: 'page',\n      // 为 docs 集合定义自定义模式\n      schema: z.object({\n        tags: z.array(z.string()),\n        image: z.string(),\n        date: z.date()\n      })\n    })\n  }\n})\n",[230,525,526,553,557,569,577,590,605,619,624,643,670,688,705,713,720,725],{"__ignoreMap":314},[318,527,528,530,532,534,536,538,540,543,545,547,549,551],{"class":320,"line":321},[318,529,325],{"class":324},[318,531,329],{"class":328},[318,533,333],{"class":332},[318,535,336],{"class":328},[318,537,339],{"class":332},[318,539,336],{"class":328},[318,541,542],{"class":332}," z",[318,544,342],{"class":328},[318,546,345],{"class":324},[318,548,348],{"class":328},[318,550,352],{"class":351},[318,552,355],{"class":328},[318,554,555],{"class":320,"line":358},[318,556,362],{"emptyLinePlaceholder":361},[318,558,559,561,563,565,567],{"class":320,"line":365},[318,560,368],{"class":324},[318,562,371],{"class":324},[318,564,339],{"class":374},[318,566,377],{"class":332},[318,568,380],{"class":328},[318,570,571,573,575],{"class":320,"line":383},[318,572,387],{"class":386},[318,574,390],{"class":328},[318,576,393],{"class":328},[318,578,579,582,584,586,588],{"class":320,"line":