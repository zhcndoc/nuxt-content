72,1280,1285,1288],[226,227,228,229,233],"p",{},"Nuxt Content 模块会自动解析位于 Nuxt 应用根目录下 ",[230,231,232],"code",{},"content/"," 文件夹中的所有内容文件。此设置允许你自由地组织文件夹结构，以满足项目需求。",[226,235,236,237,240],{},"为了更好地组织内容，你可以使用内容集合 (Content Collections)，它们帮助你更有效地分类和管理内容。这些集合在 ",[230,238,239],{},"content.config.ts"," 文件中定义。",[242,243,244],"warning",{},[226,245,246,247,249],{},"如果没有 ",[230,248,239],{}," 文件，内容文件夹中的所有文件都会被默认解析和导入。但一旦添加了配置文件，只有符合集合中指定路径模式的文件才会被导入。",[251,252,254],"h2",{"id":253},"什么是内容集合","什么是内容集合？",[226,256,257],{},"内容集合是 Nuxt Content 项目中组织相关内容的方式。它们提供了一种结构化方法来管理内容，使查询、展示和维护网站数据更加便捷。",[226,259,260],{},"关键特性包括：",[262,263,264,272,278,284,290],"ul",{},[265,266,267,271],"li",{},[268,269,270],"strong",{},"逻辑分组","：将相似内容归为一类，如博客文章、产品页面或文档",[265,273,274,277],{},[268,275,276],{},"共享配置","：对集合内所有条目应用通用设置和验证",[265,279,280,283],{},[268,281,282],{},"优化查询","：高效获取和筛选相关内容项",[265,285,286,289],{},[268,287,288],{},"自动类型推断","：在开发环境中获得类型安全和自动补全",[265,291,292,295],{},[268,293,294],{},"灵活结构","：按内容类型、类别或任何适合你的逻辑分组组织集合",[251,297,298],{"id":298},"定义集合",[226,300,301,302,304],{},"在项目根目录创建一个 ",[230,303,239],{}," 文件。这个特殊文件用于配置你的集合数据库、工具类型和内容处理。",[226,306,307],{},"以下是一个基础示例：",[309,310,315],"pre",{"className":311,"code":312,"filename":239,"language":313,"meta":314,"style":314},"language-ts shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","import { defineCollection, defineContentConfig } from '@nuxt/content'\n\nexport default defineContentConfig({\n  collections: {\n    docs: defineCollection({\n      // 加载 `content` 目录下的所有文件\n      source: '**',\n      // 指定此集合内容类型\n      type: 'page'\n    })\n  }\n})\n","ts","",[230,316,317,356,363,381,394,408,415,434,440,455,464,470],{"__ignoreMap":314},[318,319,322,326,330,334,337,340,343,346,349,353],"span",{"class":320,"line":321},"line",1,[318,323,325],{"class":324},"s7zQu","import",[318,327,329],{"class":328},"sMK4o"," {",[318,331,333],{"class":332},"sTEyZ"," defineCollection",[318,335,336],{"class":328},",",[318,338,339],{"class":332},